.privacy-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10px);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 99999;
}
.privacy-container {
  width: 85%;
  padding: 24px;
  background: #ffffff;
  border-radius: 16px;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}
.privacy-title {
  font-size: 18px;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16px;
  text-align: center;
}
.privacy-content {
  font-size: 14px;
  color: #4b5563;
  line-height: 1.6;
  margin-bottom: 24px;
}
.privacy-link {
  color: #3b6bf5;
  font-weight: 500;
  display: inline;
}
.privacy-actions {
  display: flex;
  gap: 12px;
}
.btn-disagree {
  flex: 1;
  height: 44px;
  line-height: 44px;
  text-align: center;
  border-radius: 22px;
  font-size: 15px;
  color: #6b7280;
  background: #f3f4f6;
  border: none;
  padding: 0;
  margin: 0;
}
.btn-agree {
  flex: 1;
  height: 44px;
  line-height: 44px;
  text-align: center;
  border-radius: 22px;
  font-size: 15px;
  color: #ffffff;
  background: #3b6bf5;
  border: none;
  font-weight: 500;
  padding: 0;
  margin: 0;
}
.btn-agree::after, .btn-disagree::after {
  border: none;
}
