<view class="page">
  <hj-navbar title="阻鼾器管理" show-back></hj-navbar>

  <view class="page-content">
    <picker wx:if="{{memberOptions.length}}" mode="selector" range="{{memberOptions}}" value="{{memberIndex}}" bindchange="onMemberChange" class="member-picker">
      <view class="member-picker-content">
        <view class="member-info">
          <text class="member-label">当前就诊人：</text>
          <text class="member-value">{{memberOptions[memberIndex]}}</text>
        </view>
        <view class="member-action">
          <text class="member-action-text">切换</text>
          <image class="member-action-arrow" src="/static/icons/chevron-right.svg" mode="aspectFit"></image>
        </view>
      </view>
    </picker>

    <view wx:if="{{loading}}" class="device-card loading-card">
      <text class="device-title">加载中...</text>
    </view>

    <block wx:else>
      <view wx:if="{{device}}" class="device-card">
        <view class="device-head">
          <view class="device-copy">
            <text class="device-label">当前绑定设备</text>
            <text class="device-title">{{device.device && device.device.name ? device.device.name : device.deviceModel}}</text>
            <text class="device-subtitle">{{device.patientName}}</text>
          </view>
          <image wx:if="{{device.device && device.device.imageUrl}}" class="device-image" src="{{device.device.imageUrl}}" mode="aspectFill"></image>
          <view wx:else class="device-image device-image--placeholder">
            <image class="device-image__icon" src="/static/icons/tab-treatment-active.png" mode="aspectFit"></image>
          </view>
        </view>

        <view class="device-grid">
          <view class="device-grid__item">
            <text class="device-grid__label">当前前移量</text>
            <text class="device-grid__value">{{device.adjustmentValue}}mm</text>
          </view>
          <view class="device-grid__item">
            <text class="device-grid__label">绑定日期</text>
            <text class="device-grid__value">{{device.startDate}}</text>
          </view>
          <view class="device-grid__item">
            <text class="device-grid__label">主诊医生</text>
            <text class="device-grid__value">{{device.doctorName || '未分配'}}</text>
          </view>
          <view class="device-grid__item">
            <text class="device-grid__label">下次调整</text>
            <text class="device-grid__value">{{device.nextAdjustDate || '待安排'}}</text>
          </view>
        </view>
      </view>

      <view wx:else class="device-card empty-card">
        <image class="empty-card__icon" src="/static/icons/tab-treatment-active.png" mode="aspectFit"></image>
        <text class="device-title">当前就诊人暂无阻鼾器绑定记录</text>
        <text class="device-subtitle">完成线下面诊与设备适配后，这里会展示真实绑定数据</text>
      </view>

      <view wx:if="{{device}}" class="menu-list">
        <view wx:for="{{menuItems}}" wx:key="key" class="menu-item" data-url="{{item.url}}" bindtap="goMenu">
          <view class="menu-item__icon">
            <image class="menu-item__icon-img" src="{{item.icon}}" mode="aspectFit"></image>
          </view>
          <view class="menu-item__body">
            <text class="menu-item__label">{{item.label}}</text>
            <text class="menu-item__desc">{{item.desc}}</text>
          </view>
          <image class="menu-item__arrow" src="/static/icons/chevron-right.svg" mode="aspectFit"></image>
        </view>
      </view>
    </block>

    <view class="safe-bottom"></view>
  </view>
</view>
