<view class="page">
  <hj-navbar title="维护记录" show-back></hj-navbar>

  <view class="page-content">
    <picker wx:if="{{memberOptions.length}}" mode="selector" range="{{memberOptions}}" value="{{memberIndex}}" bindchange="onMemberChange" class="member-picker">
      <view class="member-picker-content">
        <view class="member-info">
          <text class="member-label">当前就诊人：</text>
          <text class="member-value">{{memberOptions[memberIndex]}}</text>
        </view>
        <view class="member-action">
          <text class="member-action-text">切换</text>
          <image class="member-action-arrow" src="/static/icons/chevron-right.svg" mode="aspectFit"></image>
        </view>
      </view>
    </picker>

    <view wx:if="{{loading}}" class="state-wrap">
      <text class="state-text">加载中...</text>
    </view>

    <block wx:else>
      <view wx:for="{{records}}" wx:key="id" class="record-card">
        <view class="record-head">
          <view class="record-type" style="{{'background:' + item.typeBg + ';color:' + item.typeColor}}">
            <text>{{item.typeLabel}}</text>
          </view>
          <text class="record-date">{{item.date}}</text>
        </view>
        <text class="record-desc">{{item.description}}</text>
        <text wx:if="{{item.costText}}" class="record-cost">费用：{{item.costText}}</text>
      </view>

      <view wx:if="{{!records.length}}" class="state-wrap">
        <text class="state-text">当前就诊人暂无维护记录</text>
      </view>
    </block>

    <view class="safe-bottom"></view>
  </view>
</view>
