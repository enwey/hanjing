<view class="page">
  <hj-navbar title="使用反馈" show-back></hj-navbar>

  <view class="page-content">
    <picker wx:if="{{memberOptions.length}}" mode="selector" range="{{memberOptions}}" value="{{memberIndex}}" bindchange="onMemberChange" class="member-picker">
      <view class="member-picker-content">
        <view class="member-info">
          <text class="member-label">当前就诊人：</text>
          <text class="member-value">{{memberOptions[memberIndex]}}</text>
        </view>
        <view class="member-action">
          <text class="member-action-text">切换</text>
          <image class="member-action-arrow" src="/static/icons/chevron-right.svg" mode="aspectFit"></image>
        </view>
      </view>
    </picker>

    <view class="page-action">
      <button class="page-action__btn" bindtap="openComposer">提交反馈</button>
    </view>

    <view wx:if="{{loading}}" class="state-wrap">
      <text class="state-text">加载中...</text>
    </view>

    <block wx:else>
      <view wx:for="{{records}}" wx:key="id" class="record-card">
        <view class="record-head">
          <text class="record-date">{{item.date}}</text>
          <text class="record-rating">{{item.rating}} / 5</text>
        </view>
        <text class="record-content">{{item.content}}</text>
        <view wx:if="{{item.reply}}" class="record-reply">
          <text class="record-reply__label">回复</text>
          <text class="record-reply__content">{{item.reply}}</text>
        </view>
      </view>

      <view wx:if="{{!records.length}}" class="state-wrap">
        <text class="state-text">当前就诊人暂无使用反馈</text>
      </view>
    </block>
  </view>

  <view wx:if="{{showComposer}}" class="composer-mask" bindtap="closeComposer">
    <view class="composer-panel" catchtap="noop">
      <text class="composer-title">提交反馈</text>
      <view class="composer-stars">
        <text wx:for="{{ratingOptions}}" wx:key="*this" class="composer-star {{item <= rating ? 'active' : ''}}" data-value="{{item}}" bindtap="chooseRating">★</text>
      </view>
      <textarea class="composer-input" value="{{content}}" bindinput="onInputContent" placeholder="请输入佩戴体验、问题或建议"></textarea>
      <view class="composer-actions">
        <button class="composer-btn composer-btn--ghost" bindtap="closeComposer">取消</button>
        <button class="composer-btn composer-btn--primary" bindtap="submitFeedback">{{submitting ? '提交中...' : '确认提交'}}</button>
      </view>
    </view>
  </view>
</view>
