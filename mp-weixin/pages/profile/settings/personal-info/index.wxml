<view class="page data-v-acab1652"
  ><hj-navbar
    wx:if="{{a}}"
    class="data-v-acab1652"
    u-i="acab1652-0"
    bind:__l="__l"
    u-p="{{a}}" /><view class="page-content data-v-acab1652"
    ><view wx:if="{{b}}" class="loading-wrap data-v-acab1652"
      ><text class="data-v-acab1652">加载中...</text></view
    ><block wx:else
      ><view class="form-card data-v-acab1652"
        ><view class="form-row data-v-acab1652"
          ><text class="form-label data-v-acab1652">头像</text
          ><view class="avatar data-v-acab1652"
            ><text class="data-v-acab1652">{{c}}</text></view
          ></view
        ><view class="form-row data-v-acab1652"
          ><text class="form-label data-v-acab1652">昵称</text
          ><input
            wx:if="{{d}}"
            class="form-value-input data-v-acab1652"
            value="{{e}}"
            bindinput="{{f}}"
          /><text wx:else class="form-value data-v-acab1652">{{g}}</text></view
        ><view class="form-row data-v-acab1652"
          ><text class="form-label data-v-acab1652">手机号</text
          ><text class="form-value disabled data-v-acab1652">{{h}}</text></view
        ><view class="form-row data-v-acab1652"
          ><text class="form-label data-v-acab1652">身份证号</text
          ><input
            wx:if="{{i}}"
            class="form-value-input data-v-acab1652"
            placeholder="请输入18位身份证号"
            maxlength="18"
            value="{{j}}"
            bindinput="{{k}}" /><text wx:else class="form-value disabled data-v-acab1652">{{l}}</text></view
        ><view class="form-row data-v-acab1652"
          ><text class="form-label data-v-acab1652">病历号（就诊卡号）</text
          ><text class="form-value disabled data-v-acab1652">{{m}}</text></view
        ><view class="form-row data-v-acab1652"
          ><text class="form-label data-v-acab1652">性别</text
          ><text wx:if="{{n}}" class="form-value data-v-acab1652">{{s}}</text
          ><view wx:else class="form-chips data-v-acab1652"
            ><view
              class="{{['chip', 'data-v-acab1652', o && 'active']}}"
              bindtap="{{p}}"
              ><text class="data-v-acab1652">男</text></view
            ><view
              class="{{['chip', 'data-v-acab1652', q && 'active']}}"
              bindtap="{{r}}"
              ><text class="data-v-acab1652">女</text></view
            ></view
          ></view
        ><view class="form-row data-v-acab1652"
          ><text class="form-label data-v-acab1652">生日</text
          ><picker
            wx:if="{{t}}"
            class="form-value-input data-v-acab1652"
            mode="date"
            value="{{u}}"
            start="1900-01-01"
            end="2026-06-23"
            bindchange="{{v}}"
          >
            <view class="picker-text data-v-acab1652" style="min-height: 20px; line-height: 20px;">{{u || '请选择生日'}}</view>
          </picker><text wx:else class="form-value data-v-acab1652">{{w}}</text></view
        ></view
      ><view class="actions data-v-acab1652"
        ><view wx:if="{{x}}" class="btn-edit data-v-acab1652" bindtap="{{A}}"
          ><text class="data-v-acab1652">编辑资料</text></view
        ><block wx:else
          ><view class="btn-save data-v-acab1652" bindtap="{{y}}"
            ><text class="data-v-acab1652">保存</text></view
          ><view class="btn-cancel data-v-acab1652" bindtap="{{z}}"
            ><text class="data-v-acab1652">取消</text></view
          ></block
        ></view
      ></block
    ><view class="safe-bottom data-v-acab1652" /></view
></view>
