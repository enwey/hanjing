<view class="page data-v-ecc58349"
  ><hj-navbar
    wx:if="{{a}}"
    class="data-v-ecc58349"
    u-i="ecc58349-0"
    bind:__l="__l"
    u-p="{{a}}" /><view class="page-content data-v-ecc58349"
    ><view wx:if="{{b}}" class="loading-wrap data-v-ecc58349"
      ><text class="data-v-ecc58349">加载中...</text></view
    ><block wx:elif="{{c}}"
      ><view class="info-group data-v-ecc58349"
        ><view class="info-row data-v-ecc58349" bindtap="{{onOpenPhoneModal}}"
          ><text class="info-label data-v-ecc58349">绑定手机</text
          ><text class="info-val data-v-ecc58349" style="color: #3B6BF5;">{{d}} ✎</text></view
        ><view class="info-row data-v-ecc58349"
          ><text class="info-label data-v-ecc58349">登录密码</text
          ><text class="info-val data-v-ecc58349">{{e}}</text></view
        ><view class="info-row data-v-ecc58349" bindtap="{{onOpenRealnameModal}}"
          ><text class="info-label data-v-ecc58349">实名认证</text
          ><text class="info-val success data-v-ecc58349" style="color: #3B6BF5;">{{f}} ✎</text></view
        ></view
      ><view class="info-group data-v-ecc58349"
        ><view class="info-row data-v-ecc58349"
          ><text class="info-label data-v-ecc58349">最近登录</text
          ><text class="info-val data-v-ecc58349">{{g}}</text></view
        ><view class="info-row data-v-ecc58349"
          ><text class="info-label data-v-ecc58349">登录设备</text
          ><text class="info-val data-v-ecc58349">{{h}}</text></view
        ></view
      ><view class="btn-logout data-v-ecc58349" bindtap="{{i}}"
        ><text class="data-v-ecc58349">退出登录</text></view
      ></block
    >
    
    <!-- Phone Change Modal -->
    <view wx:if="{{showPhoneModal}}" class="modal-overlay data-v-ecc58349" bindtap="{{onClosePhoneModal}}" style="position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:999; display:flex; align-items:center; justify-content:center;">
      <view class="modal-card data-v-ecc58349" catchtap="true" style="background:#fff; border-radius:16rpx; padding:40rpx; width:80%; box-sizing:border-box;">
        <view class="modal-header data-v-ecc58349" style="font-size:32rpx; font-weight:bold; text-align:center; margin-bottom:30rpx; color:#1f2937;">更换绑定手机</view>
        <view class="modal-body data-v-ecc58349" style="display:flex; flex-direction:column; gap:24rpx; margin-bottom:40rpx;">
          <view style="border-bottom:1rpx solid #e5e7eb; padding:16rpx 0; display:flex; align-items:center;">
            <input placeholder="请输入新手机号" type="number" maxlength="11" value="{{inputPhone}}" bindinput="{{onPhoneInput}}" style="flex:1; font-size:28rpx; color:#374151;" />
          </view>
          <view style="border-bottom:1rpx solid #e5e7eb; padding:16rpx 0; display:flex; align-items:center; justify-content:space-between;">
            <input placeholder="请输入短信验证码" type="number" maxlength="6" value="{{inputCode}}" bindinput="{{onCodeInput}}" style="flex:1; font-size:28rpx; color:#374151;" />
            <text bindtap="{{onGetCode}}" style="color:#3B6BF5; font-size:26rpx; font-weight:600; padding:10rpx 0 10rpx 20rpx; z-index:1000;">获取验证码</text>
          </view>
        </view>
        <view class="modal-actions data-v-ecc58349" style="display:flex; gap:20rpx;">
          <button bindtap="{{onClosePhoneModal}}" style="flex:1; background:#f3f4f6; color:#4b5563; font-size:28rpx; border:none; border-radius:8rpx; height:80rpx; line-height:80rpx;">取消</button>
          <button bindtap="{{onSubmitPhone}}" style="flex:1; background:#3B6BF5; color:#fff; font-size:28rpx; border:none; border-radius:8rpx; height:80rpx; line-height:80rpx;">确认修改</button>
        </view>
      </view>
    </view>

    <!-- Realname Verify Modal -->
    <view wx:if="{{showRealnameModal}}" class="modal-overlay data-v-ecc58349" bindtap="{{onCloseRealnameModal}}" style="position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.5); z-index:999; display:flex; align-items:center; justify-content:center;">
      <view class="modal-card data-v-ecc58349" catchtap="true" style="background:#fff; border-radius:16rpx; padding:40rpx; width:80%; box-sizing:border-box;">
        <view class="modal-header data-v-ecc58349" style="font-size:32rpx; font-weight:bold; text-align:center; margin-bottom:30rpx; color:#1f2937;">严肃医疗实名认证</view>
        <view class="modal-body data-v-ecc58349" style="display:flex; flex-direction:column; gap:24rpx; margin-bottom:40rpx;">
          <view style="border-bottom:1rpx solid #e5e7eb; padding:16rpx 0;">
            <input placeholder="真实姓名（需与身份证一致）" value="{{inputRealName}}" bindinput="{{onRealNameInput}}" style="font-size:28rpx; color:#374151;" />
          </view>
          <view style="border-bottom:1rpx solid #e5e7eb; padding:16rpx 0;">
            <input placeholder="18位身份证号" maxlength="18" value="{{inputIdCard}}" bindinput="{{onIdCardInput}}" style="font-size:28rpx; color:#374151;" />
          </view>
        </view>
        <view class="modal-actions data-v-ecc58349" style="display:flex; gap:20rpx;">
          <button bindtap="{{onCloseRealnameModal}}" style="flex:1; background:#f3f4f6; color:#4b5563; font-size:28rpx; border:none; border-radius:8rpx; height:80rpx; line-height:80rpx;">取消</button>
          <button bindtap="{{onSubmitRealname}}" style="flex:1; background:#3B6BF5; color:#fff; font-size:28rpx; border:none; border-radius:8rpx; height:80rpx; line-height:80rpx;">立即认证</button>
        </view>
      </view>
    </view>
    
    <view class="safe-bottom data-v-ecc58349" /></view
></view>
