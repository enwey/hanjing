<view class="page">
  <hj-navbar title="病历档案" show-back></hj-navbar>

  <view class="page-content">
    <picker wx:if="{{memberOptions.length}}" mode="selector" range="{{memberOptions}}" value="{{memberIndex}}" bindchange="onMemberChange" class="member-picker">
      <view class="member-picker-content">
        <view class="member-info">
          <text class="member-label">当前就诊人：</text>
          <text class="member-value">{{memberOptions[memberIndex]}}</text>
        </view>
        <view class="member-action">
          <text class="member-action-text">切换</text>
          <image class="member-action-arrow" src="/static/icons/chevron-right.svg" mode="aspectFit"></image>
        </view>
      </view>
    </picker>

    <view wx:if="{{loading}}" class="loading-wrap">
      <text class="loading-text">加载中...</text>
    </view>

    <block wx:else>
      <view wx:for="{{records}}" wx:key="id" class="record-card">
        <view class="record-header">
          <view class="record-type" style="{{'background:' + item.typeBg + ';color:' + item.typeColor}}">
            <text>{{item.typeLabel}}</text>
          </view>
          <text class="record-date">{{item.visitDate}}</text>
        </view>
        <text class="record-patient">{{item.patientName}}</text>
        <text class="record-doctor">{{item.doctorName}} 医生 | {{item.hospital}}</text>

        <view class="record-section">
          <text class="record-label">诊断</text>
          <text class="record-value">{{item.diagnosis}}</text>
        </view>

        <view wx:if="{{item.prescription}}" class="record-section">
          <text class="record-label">处方/方案</text>
          <text class="record-value">{{item.prescription}}</text>
        </view>

        <view wx:if="{{item.note}}" class="record-note">
          <text>{{item.note}}</text>
        </view>
      </view>

      <view wx:if="{{!records.length}}" class="empty-state">
        <text class="empty-text">当前就诊人暂无病历档案</text>
      </view>
    </block>

    <view class="safe-bottom"></view>
  </view>
</view>
