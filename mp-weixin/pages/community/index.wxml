          ></view
        ><text wx:if="{{post.g}}" class="post-title data-v-b7ab25fd">{{post.h}}</text
        ><text class="post-content data-v-b7ab25fd">{{post.i}}</text
        ><view class="post-tags data-v-b7ab25fd"
          ><text wx:if="{{post.j}}" class="{{['post-category', 'data-v-b7ab25fd', post.l]}}"
            >{{post.k}}</text
          ><block wx:if="{{post.m}}"
            ><text
              wx:for="{{post.n}}"
              wx:for-item="tag"
              wx:key="b"
              class="post-tag data-v-b7ab25fd"
              >{{tag.a}}</text
            ></block
          ></view
        ><view class="post-actions data-v-b7ab25fd"
          ><view class="action-item data-v-b7ab25fd" catchtap="{{post.r}}"
            ><image class="{{['action-icon', 'data-v-b7ab25fd', post.p]}}" src="{{post.o}}" mode="aspectFit"></image
            ><text class="action-count data-v-b7ab25fd">{{post.q}}</text></view
          ><view class="action-item data-v-b7ab25fd" catchtap="{{post.t}}"
            ><image class="action-icon data-v-b7ab25fd" src="/static/icons/chat.svg" mode="aspectFit"></image
            ><text class="action-count data-v-b7ab25fd">{{post.s}}</text></view
          ><view class="action-item data-v-b7ab25fd"
            ><image class="action-icon data-v-b7ab25fd" src="/static/icons/paper-plane.svg" mode="aspectFit"></image
            ><text class="action-count data-v-b7ab25fd">分享</text></view
          ></view
        ></view
      ><view wx:if="{{e}}" class="empty-tip data-v-b7ab25fd"
        ><text class="data-v-b7ab25fd">暂无帖子，来发第一帖吧！</text></view
      ></view
    ></view
  ><view class="fab data-v-b7ab25fd" bindtap="{{f}}"><image class="fab-icon data-v-b7ab25fd" src="/static/icons/compose-white.svg" mode="aspectFit"></image></view></view
>
