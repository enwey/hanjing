              src="{{post.b}}"
              mode="aspectFill"
            ></image></view
          ><view class="post-author-info data-v-b7ab25fd"
            ><view class="post-author-row data-v-b7ab25fd"
              ><text class="post-author data-v-b7ab25fd">{{post.c}}</text
              ><text class="{{['post-role', 'data-v-b7ab25fd', post.e]}}"
                >{{post.d}}</text
              ></view
