      ><view class="publish-btn data-v-b7ab25fd">发帖</view></view
    ><view class="tabs data-v-b7ab25fd"
      ><view
        wx:for="{{c}}"
        wx:for-item="tab"
        wx:key="b"
        class="{{['tab', 'data-v-b7ab25fd', tab.c && 'active']}}"
        bindtap="{{tab.d}}"
        >{{tab.a}}</view
      ></view
    ><view class="post-list data-v-b7ab25fd"
      ><view
        wx:for="{{d}}"
        wx:for-item="post"
        wx:key="u"
