.data-v-b7ab25fd:root {
  --color-primary-50: #eef4ff;
  --color-primary-100: #d9e6ff;
  --color-primary-300: #8eafff;
  --color-primary-500: #3b6bf5;
  --color-primary-600: #2a52d4;
  --color-primary-800: #1a3580;
  --color-gray-100: #f3f4f6;
  --color-gray-200: #e5e7eb;
  --color-gray-400: #9ca3af;
  --color-gray-600: #4b5563;
  --color-gray-800: #1f2937;
  --safe-bottom: env(safe-area-inset-bottom, 34px);
}
.page.data-v-b7ab25fd {
  min-height: 100vh;
  background: #f3f4f6;
  display: flex;
  flex-direction: column;
}
.page-content.data-v-b7ab25fd {
  flex: 1;
  padding: 0 16px 80px;
}
.publish-entry.data-v-b7ab25fd {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #fff;
  border-radius: 12px;
  padding: 12px 16px;
  margin: 12px 0;
}
.publish-icon.data-v-b7ab25fd {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
}
.publish-placeholder.data-v-b7ab25fd {
  flex: 1;
  font-size: 14px;
  color: #9ca3af;
}
.publish-btn.data-v-b7ab25fd {
  background: #3b6bf5;
  color: #fff;
  font-size: 13px;
  font-weight: 600;
  padding: 6px 16px;
  border-radius: 8px;
}
.tabs.data-v-b7ab25fd {
  display: flex;
  background: #fff;
  border-radius: 10px;
  padding: 4px;
  margin-bottom: 12px;
}
.tab.data-v-b7ab25fd {
  flex: 1;
  text-align: center;
  padding: 8px 0;
  border-radius: 8px;
  font-size: 14px;
  color: #6b7280;
}
.tab.active.data-v-b7ab25fd {
  background: #3b6bf5;
  color: #fff;
  font-weight: 600;
}
.post-list.data-v-b7ab25fd {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.post-card.data-v-b7ab25fd {
  background: #fff;
  border-radius: 14px;
  padding: 16px;
  position: relative;
}
.post-top.data-v-b7ab25fd {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  background: #fff9e6;
  padding: 2px 8px;
  border-radius: 4px;
  margin-bottom: 8px;
}
.top-icon.data-v-b7ab25fd {
  width: 12px;
  height: 12px;
  flex-shrink: 0;
}
.top-text.data-v-b7ab25fd {
  font-size: 10px;
  color: #f5a623;
  font-weight: 600;
}
.post-header.data-v-b7ab25fd {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}
.post-avatar.data-v-b7ab25fd {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #e5e7eb;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}
.post-avatar-image.data-v-b7ab25fd {
  width: 100%;
  height: 100%;
}
.post-author-info.data-v-b7ab25fd {
  flex: 1;
}
.post-author-row.data-v-b7ab25fd {
  display: flex;
  align-items: center;
  gap: 6px;
}
.post-author.data-v-b7ab25fd {
  font-size: 14px;
  font-weight: 600;
  color: #1f2937;
}
.post-role.data-v-b7ab25fd {
  font-size: 10px;
  padding: 1px 6px;
  border-radius: 4px;
}
.post-role.role--doctor.data-v-b7ab25fd {
  background: #eef4ff;
  color: #3b6bf5;
}
.post-role.role--expert.data-v-b7ab25fd {
  background: #f5f3ff;
  color: #8b5cf6;
}
.post-role.role--patient.data-v-b7ab25fd {
  background: #f0fdf4;
  color: #1a9d5c;
}
.post-time.data-v-b7ab25fd {
  font-size: 11px;
  color: #9ca3af;
  display: block;
  margin-top: 2px;
}
.post-title.data-v-b7ab25fd {
  font-size: 15px;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 6px;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.post-content.data-v-b7ab25fd {
  font-size: 13px;
  color: #4b5563;
  line-height: 1.6;
  display: block;
  margin-bottom: 8px;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}
.post-tags.data-v-b7ab25fd {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 10px;
}
.post-category.data-v-b7ab25fd,
.post-tag.data-v-b7ab25fd {
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 4px;
}
.post-tag.data-v-b7ab25fd {
  color: #3b6bf5;
  background: #eef4ff;
}
.post-category.tag-theme--blue.data-v-b7ab25fd {
  color: #2a52d4;
  background: #e8f0ff;
}
.post-category.tag-theme--green.data-v-b7ab25fd {
  color: #138a52;
  background: #e8f8ef;
}
.post-category.tag-theme--orange.data-v-b7ab25fd {
  color: #d97706;
  background: #fff3df;
}
.post-category.tag-theme--amber.data-v-b7ab25fd {
  color: #b7791f;
  background: #fff8db;
}
.post-category.tag-theme--pink.data-v-b7ab25fd {
  color: #c2417a;
  background: #ffe8f1;
}
.post-category.tag-theme--violet.data-v-b7ab25fd {
  color: #6d4fd6;
  background: #f0ebff;
}
.post-actions.data-v-b7ab25fd {
  display: flex;
  gap: 20px;
  padding-top: 10px;
  border-top: 1px solid #f3f4f6;
}
.action-item.data-v-b7ab25fd {
  display: flex;
  align-items: center;
  gap: 4px;
}
.action-icon.data-v-b7ab25fd {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}
.action-icon.liked.data-v-b7ab25fd {
  transform: scale(1.04);
}
.action-count.data-v-b7ab25fd {
  font-size: 12px;
  color: #9ca3af;
}
.fab.data-v-b7ab25fd {
  position: fixed;
  right: 20px;
  bottom: calc(20px + var(--safe-bottom));
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b6bf5, #5a85f5);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(59, 107, 245, 0.35);
  z-index: 100;
}
.fab-icon.data-v-b7ab25fd {
  width: 22px;
  height: 22px;
}
.empty-tip.data-v-b7ab25fd {
  text-align: center;
  padding: 40px 0;
  color: #9ca3af;
  font-size: 13px;
}
