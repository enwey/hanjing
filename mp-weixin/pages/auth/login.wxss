.login-page {
  padding: 40px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: calc(100vh - 88px);
  box-sizing: border-box;
}
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40px;
  text-align: center;
}
.logo-container {
  width: 88px;
  height: 88px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b6bf5, #8eafff);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(59, 107, 245, 0.25);
  margin-bottom: 20px;
}
.logo-emoji {
  font-size: 40px;
}
.brand-name {
  font-size: 24px;
  font-weight: 700;
  color: #1a3580;
  margin-bottom: 8px;
}
.brand-slogan {
  font-size: 13px;
  color: #6b7280;
}
.auth-section {
  width: 100%;
  margin-top: 50px;
  margin-bottom: auto;
}
.auth-tip-card {
  background: #f9fafb;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 24px;
  border: 1px solid #e5e7eb;
}
.tip-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}
.tip-icon {
  font-size: 16px;
}
.tip-title {
  font-size: 14px;
  font-weight: 600;
  color: #374151;
}
.tip-content {
  font-size: 13px;
  color: #6b7280;
  line-height: 1.6;
  display: block;
}
.auth-btn {
  width: 100%;
  height: 50px;
  line-height: 50px;
  background: #07c160;
  color: #fff;
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  border: none;
  text-align: center;
  box-shadow: 0 4px 12px rgba(7, 193, 96, 0.25);
  margin-bottom: 16px;
}
.auth-btn:active {
  opacity: 0.9;
}
.cancel-btn {
  width: 100%;
  height: 50px;
  line-height: 50px;
  background: #f3f4f6;
  color: #4b5563;
  font-size: 16px;
  font-weight: 600;
  border-radius: 12px;
  border: none;
  text-align: center;
  margin-bottom: 20px;
}
.cancel-btn:active {
  background: #e5e7eb;
}
.cancel-btn:after, .auth-btn:after {
  border: none;
}
.protocol-section {
  font-size: 11px;
  color: #9ca3af;
  text-align: center;
  margin-top: 30px;
}
.protocol-text {
  color: #9ca3af;
}
.protocol-link {
  color: #3b6bf5;
  display: inline;
}
