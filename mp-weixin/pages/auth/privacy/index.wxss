.privacy-page {
  min-height: 100vh;
  background: #f9fafb;
  display: flex;
  flex-direction: column;
}
.privacy-content {
  flex: 1;
  padding: 20px 16px;
  box-sizing: border-box;
}
.article-title {
  font-size: 20px;
  font-weight: 700;
  color: #111827;
  text-align: center;
  margin-bottom: 8px;
}
.article-meta {
  font-size: 12px;
  color: #9ca3af;
  text-align: center;
  margin-bottom: 24px;
}
.section {
  background: #ffffff;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.05);
}
.section-title {
  font-size: 15px;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 10px;
}
.section-text {
  font-size: 13px;
  color: #4b5563;
  line-height: 1.7;
  display: block;
}
