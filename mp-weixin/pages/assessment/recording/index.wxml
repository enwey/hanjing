<view class="page data-v-70350287"
  ><view class="star star-1 data-v-70350287"></view
  ><view class="star star-2 data-v-70350287"></view
  ><view class="star star-3 data-v-70350287"></view
  ><view class="star star-4 data-v-70350287"></view
  ><hj-navbar
    wx:if="{{navbarProps}}"
    class="data-v-70350287"
    bindback="{{handleBack}}"
    u-i="70350287-0"
    bind:__l="__l"
    u-p="{{navbarProps}}" /><view wx:if="{{!y}}" class="page-content data-v-70350287"
    ><picker mode="selector" range="{{memberNames}}" value="{{memberIndex}}" bindchange="{{onMemberChange}}" disabled="{{disabledSelector}}" class="member-picker data-v-70350287"
      ><view class="member-picker-content data-v-70350287"
        ><view class="member-info data-v-70350287"
          ><text class="member-label data-v-70350287">当前检测人：</text
          ><text class="member-value data-v-70350287">{{selectedMemberName}}</text></view
        ><view wx:if="{{!disabledSelector}}" class="member-action data-v-70350287"
          ><text class="member-action-text data-v-70350287">切换</text
          ><image class="member-action-arrow data-v-70350287" src="/static/icons/chevron-right.svg" mode="aspectFit" /></view
      ></view
    ></picker><view class="guide-card data-v-70350287"
      ><text class="guide-emoji data-v-70350287">💤</text
      ><text class="guide-title data-v-70350287">睡眠呼吸监测</text
      ><text class="guide-desc data-v-70350287">本地AI离线解析 · 0音频上传保障隐私</text></view
    ><view class="record-area data-v-70350287"
      ><view class="{{['waveform', 'data-v-70350287', waveVisible ? 'is-visible' : 'is-hidden']}}" style="{{'--volume-scale:' + volScale}}"
        ><view
          wx:for="{{c}}"
          wx:for-item="history"
          wx:key="a"
          class="{{['wave-bar', 'data-v-70350287', d && 'wave-bar--live']}}"
          style="{{'height:' + history.b + ';' + ('animation-delay:' + history.c)}}" /></view
      ><text class="{{['record-time', 'data-v-70350287', e ? 'is-visible' : 'is-hidden']}}">{{f}}</text
      ><view class="mic-btn-wrapper data-v-70350287"
        ><view class="ring-glow ring-glow-1 data-v-70350287"
        /><view class="ring-glow ring-glow-2 data-v-70350287"
        /><view class="ring-glow ring-glow-3 data-v-70350287"
        /><view
          class="{{['mic-pulse', 'data-v-70350287', g && 'mic-pulse--active']}}"
        /><view
          class="{{['mic-btn', 'data-v-70350287', k && 'mic-btn--recording', l && 'mic-btn--paused', m && 'mic-btn--done', n && 'mic-btn--analyzing']}}"
          bindtap="{{o}}"
          ><text wx:if="{{showPlayIcon}}" class="mic-icon data-v-70350287">▶</text
          ><text wx:elif="{{showPauseIcon}}" class="mic-icon data-v-70350287">⏸</text
          ><text wx:elif="{{showAnalyzingIcon}}" class="mic-icon data-v-70350287">...</text
          ></view
        ></view
      ><text class="{{['status-text', 'data-v-70350287', statusClass, showStatusText ? 'is-visible' : 'is-hidden']}}"
        >{{statusText}}</text></view
    ><view class="{{['actions', 'data-v-70350287', v ? 'is-visible' : 'is-hidden']}}"
      ><view class="btn btn--primary data-v-70350287" bindtap="{{x}}"
        ><text class="data-v-70350287">生成分析报告</text></view
      ></view
    ><view class="tips-card data-v-70350287"
      ><text class="tips-title data-v-70350287">使用指引</text
      ><view class="tips-list data-v-70350287"
        ><text class="tip-item data-v-70350287">• 手机放置于床头约50cm处</text
        ><text class="tip-item data-v-70350287">• 麦克风朝上并避开持续强噪</text
        ><text class="tip-item data-v-70350287"
          >• 建议连接充电器监测整夜</text
        ></view
      ></view
    ></view
  ><view wx:else class="analyzing-screen data-v-70350287"
    ><view class="analyzing-card data-v-70350287"
      ><view class="spinner data-v-70350287" /><text
        class="analyzing-text data-v-70350287"
        >正在分析...</text
      ><text class="analyzing-hint data-v-70350287">约需 2-3 秒</text></view
    ></view
  ><view class="safe-bottom data-v-70350287" />
  <hj-privacy-popup id="privacyPopup" />
</view>
