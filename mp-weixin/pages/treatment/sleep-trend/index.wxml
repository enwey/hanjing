<view class="page data-v-eb41b617"
  ><hj-navbar
    wx:if="{{a}}"
    class="data-v-eb41b617"
    u-i="eb41b617-0"
    bind:__l="__l"
    u-p="{{a}}" /><view wx:if="{{b}}" class="page-content data-v-eb41b617"
    ><block wx:if="{{c}}"
      ><view class="mode-switch data-v-eb41b617"
      ><view
        class="{{['mode-btn', 'data-v-eb41b617', d && 'mode-btn--active']}}"
        bindtap="{{e}}"
        >本周</view
      ><view
        class="{{['mode-btn', 'data-v-eb41b617', f && 'mode-btn--active']}}"
        bindtap="{{g}}"
        >全部</view
      ></view
    ><view class="summary-row data-v-eb41b617"
      ><view class="summary-item data-v-eb41b617"
        ><text class="summary-val data-v-eb41b617">{{h}}天</text
        ><text class="summary-lbl data-v-eb41b617">佩戴天数</text></view
      ><view class="summary-item data-v-eb41b617"
        ><text class="summary-val data-v-eb41b617">{{i}}h</text
        ><text class="summary-lbl data-v-eb41b617">日均时长</text></view
      ><view class="summary-item data-v-eb41b617"
        ><text class="summary-val data-v-eb41b617">{{j}}%</text
        ><text class="summary-lbl data-v-eb41b617">依从率</text></view
      ></view
    ><view class="chart-card data-v-eb41b617"
      ><text class="chart-title data-v-eb41b617">每日佩戴时长</text
      ><view class="chart-bars data-v-eb41b617"
        ><view
          wx:for="{{k}}"
          wx:for-item="dataItem"
          wx:key="f"
          class="bar-col data-v-eb41b617"
          ><text wx:if="{{dataItem.a}}" class="bar-value data-v-eb41b617"
            >{{dataItem.b}}h</text
          ><text wx:else class="bar-value bar-value--zero data-v-eb41b617"
            >-</text
          ><view
            class="bar-fill data-v-eb41b617"
            style="{{'height:' + dataItem.c + ';' + ('background:' + dataItem.d)}}"
          /><text class="bar-label data-v-eb41b617">{{dataItem.e}}</text></view
        ></view
      ><text class="chart-hint data-v-eb41b617">参考线：目标 7h</text></view
    ><view class="chart-card data-v-eb41b617"
      ><text class="chart-title data-v-eb41b617">舒适度评分</text
      ><view class="comfort-grid data-v-eb41b617"
        ><view
          wx:for="{{l}}"
          wx:for-item="dataItem"
          wx:key="c"
          class="{{['comfort-cell', 'data-v-eb41b617', dataItem.d && 'comfort-cell--empty']}}"
          ><view class="comfort-dots data-v-eb41b617"
            ><view
              wx:for="{{dataItem.a}}"
              wx:for-item="dot"
              wx:key="a"
              class="{{['comfort-dot', 'data-v-eb41b617', dot.b && 'comfort-dot--on']}}" /></view
          ><text class="comfort-date data-v-eb41b617">{{dataItem.b}}</text></view
        ></view
      ></view></block
    ><view wx:else class="empty-card data-v-eb41b617"
      ><text class="empty-title data-v-eb41b617">{{m}}</text
      ><text class="empty-desc data-v-eb41b617">{{n}}</text></view
    ><view class="safe-bottom data-v-eb41b617" /></view
></view>
