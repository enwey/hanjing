          class="{{['checkin-btn-submit', 'data-v-8badcb8c', H && 'checkin-btn-submit--loading']}}"
          bindtap="{{I}}"
          ><text class="data-v-8badcb8c">{{G}}</text></view
        ></view
      ></view
    ></view
  ></view
>
