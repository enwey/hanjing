        ><text class="menu-desc data-v-8badcb8c">佩戴与睡眠数据</text></view
      ><view class="menu-item data-v-8badcb8c" bindtap="{{q}}"
        ><image class="menu-icon menu-icon--report data-v-8badcb8c" src="/static/icons/report.svg" />
