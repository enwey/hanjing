<view class="page data-v-5e948475"
  ><hj-navbar
    wx:if="{{a}}"
    class="data-v-5e948475"
    u-i="5e948475-0"
    bind:__l="__l"
    u-p="{{a}}"
  /><view wx:if="{{b}}" class="loading-wrap data-v-5e948475"
    ><text class="data-v-5e948475">加载中...</text></view
  ><block wx:elif="{{c}}"
    ><swiper
      class="img-swiper data-v-5e948475"
      current="{{e}}"
      bindchange="{{f}}"
      indicator-dots
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#3B6BF5"
      ><swiper-item
        wx:for="{{d}}"
        wx:for-item="img"
        wx:key="b"
        class="data-v-5e948475"
        ><image
          class="swiper-img data-v-5e948475"
          src="{{img.a}}"
          mode="aspectFill" /></swiper-item></swiper
    ><view class="body data-v-5e948475"
      ><view class="header data-v-5e948475"
        ><view class="price-row data-v-5e948475"
          ><text class="price data-v-5e948475">{{g}}</text
          ><text wx:if="{{h}}" class="price-original data-v-5e948475"
            >{{i}}</text
          ><text wx:if="{{j}}" class="discount-tag data-v-5e948475"
            >{{k}}% OFF</text
          ></view
        ><text class="name data-v-5e948475">{{l}}</text
        ><text class="sales data-v-5e948475">已售 {{m}}</text></view
      ><view class="section data-v-5e948475"
        ><text class="section-title data-v-5e948475">商品详情</text
        ><text class="desc data-v-5e948475">{{n}}</text></view
      ></view
    ><view class="bottom-bar data-v-5e948475"
      ><view class="bottom-price data-v-5e948475"
        ><text class="bottom-price-val data-v-5e948475">{{o}}</text></view
      ><view class="btn-buy data-v-5e948475" bindtap="{{p}}"
        ><text class="data-v-5e948475">立即购买</text></view
      ></view
    ><view wx:if="{{showCheckout}}" class="checkout-overlay data-v-5e948475" bindtap="closeCheckout">
      <view class="checkout-panel data-v-5e948475" catchtap="true">
        <view class="checkout-close data-v-5e948475" bindtap="closeCheckout">×</view>
        <text class="checkout-title data-v-5e948475">确认订单</text>
        <view class="checkout-product-card data-v-5e948475">
          <image class="checkout-product-img data-v-5e948475" src="{{productImageUrl}}" mode="aspectFill" />
          <view class="checkout-product-info data-v-5e948475">
            <text class="checkout-product-name data-v-5e948475">{{l}}</text>
            <text class="checkout-product-price data-v-5e948475">{{o}}</text>
          </view>
        </view>
        <view class="checkout-row data-v-5e948475">
          <text class="checkout-label data-v-5e948475">购买数量</text>
          <view class="qty-selector data-v-5e948475">
            <view class="qty-btn data-v-5e948475" bindtap="decreaseQty">-</view>
            <text class="qty-val data-v-5e948475">{{quantity}}</text>
            <view class="qty-btn data-v-5e948475" bindtap="increaseQty">+</view>
          </view>
        </view>
        <view class="checkout-address-section data-v-5e948475">
          <text class="checkout-section-title data-v-5e948475">收货人信息</text>
          <view class="input-group data-v-5e948475">
            <text class="input-label data-v-5e948475">收货人</text>
            <input class="checkout-input data-v-5e948475" type="text" value="{{contactName}}" bindinput="inputName" placeholder="收货人姓名" />
          </view>
          <view class="input-group data-v-5e948475">
            <text class="input-label data-v-5e948475">联系电话</text>
            <input class="checkout-input data-v-5e948475" type="number" value="{{phone}}" bindinput="inputPhone" placeholder="联系手机号" />
          </view>
          <view class="input-group data-v-5e948475">
            <text class="input-label data-v-5e948475">详细地址</text>
            <input class="checkout-input data-v-5e948475" type="text" value="{{detailAddress}}" bindinput="inputDetail" placeholder="省市区及详细地址" />
          </view>
        </view>
        <view class="checkout-footer data-v-5e948475">
          <view class="checkout-total data-v-5e948475">
            <text class="checkout-total-label data-v-5e948475">实付款：</text>
            <text class="checkout-total-val data-v-5e948475">{{totalPayAmountText}}</text>
          </view>
          <view class="checkout-btn-submit data-v-5e948475" bindtap="submitOrder">
            <text class="data-v-5e948475">{{isSubmitting ? '正在提交...' : '确认支付'}}</text>
          </view>
        </view>
      </view>
    </view></block
  ></view
>
