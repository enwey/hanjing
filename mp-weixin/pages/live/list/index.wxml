<view class="page data-v-b8fa8280">
  <hj-navbar title="直播中心" show-back="{{true}}" />

  <view class="tabs data-v-b8fa8280">
    <view class="tab data-v-b8fa8280 {{activeTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="switchTab">全部</view>
    <view class="tab data-v-b8fa8280 {{activeTab === 'live' ? 'active' : ''}}" data-tab="live" bindtap="switchTab">直播中</view>
    <view class="tab data-v-b8fa8280 {{activeTab === 'upcoming' ? 'active' : ''}}" data-tab="upcoming" bindtap="switchTab">预告</view>
    <view class="tab data-v-b8fa8280 {{activeTab === 'replay' ? 'active' : ''}}" data-tab="replay" bindtap="switchTab">回放</view>
  </view>

  <view class="list data-v-b8fa8280">
    <view
      wx:for="{{filteredRooms}}"
      wx:key="id"
      class="card data-v-b8fa8280"
      data-id="{{item.id}}"
      bindtap="openRoomDetail"
    >
      <view class="cover-wrap data-v-b8fa8280">
        <image class="cover data-v-b8fa8280" src="{{item.cover}}" mode="aspectFill" />
        <view class="cover-tag data-v-b8fa8280 {{item.status}}">{{item.statusText}}</view>
        <view wx:if="{{item.startTime}}" class="cover-time data-v-b8fa8280">{{item.displayTime}}</view>
      </view>

      <view class="card-body data-v-b8fa8280">
        <text class="card-title data-v-b8fa8280">{{item.title}}</text>
        <view class="card-meta data-v-b8fa8280">
          <view class="anchor data-v-b8fa8280">
            <text class="anchor-avatar data-v-b8fa8280">{{item.anchorInitial}}</text>
            <text class="anchor-name data-v-b8fa8280">{{item.anchorName}}</text>
          </view>
          <text wx:if="{{item.showViewerCount}}" class="views data-v-b8fa8280">{{item.displayViewerCount}}人观看</text>
        </view>
        <view class="tags data-v-b8fa8280">
          <text wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this" class="tag data-v-b8fa8280">{{tag}}</text>
        </view>
        <view class="action-line data-v-b8fa8280">
          <text class="room-id data-v-b8fa8280">微信直播间ID：{{item.displayRoomId}}</text>
          <view class="action-btn data-v-b8fa8280">{{item.actionText}}</view>
        </view>
      </view>
    </view>

    <hj-empty wx:if="{{showEmpty}}" text="暂无直播" />
  </view>
</view>
