<view class="page data-v-baa6e4ef"
  ><hj-navbar
    wx:if="{{a}}"
    class="data-v-baa6e4ef"
    u-i="baa6e4ef-0"
    bind:__l="__l"
    u-p="{{a}}"
  /><view class="page-content data-v-baa6e4ef"
    ><view class="success-icon data-v-baa6e4ef"
      ><image class="success-medical-icon data-v-baa6e4ef" mode="aspectFit" src="/static/icons/success-medical.svg" /></view
    ><text class="success-title data-v-baa6e4ef">预约成功</text
    ><text class="success-desc data-v-baa6e4ef">您的预约已提交，请按时就诊</text
    ><view class="summary-card data-v-baa6e4ef"
      ><view class="summary-row data-v-baa6e4ef"
        ><text class="summary-label data-v-baa6e4ef">预约单号</text
        ><text class="summary-value summary-value--no data-v-baa6e4ef"
          >{{b}}</text
        ></view
      ><view class="summary-row data-v-baa6e4ef"
        ><text class="summary-label data-v-baa6e4ef">就诊门店</text
        ><text class="summary-value data-v-baa6e4ef">{{c}}</text></view
      ><view class="summary-row data-v-baa6e4ef"
        ><text class="summary-label data-v-baa6e4ef">就诊医生</text
        ><text class="summary-value data-v-baa6e4ef">{{d}}</text></view
      ><view class="summary-row data-v-baa6e4ef"
        ><text class="summary-label data-v-baa6e4ef">就诊时间</text
        ><text class="summary-value summary-value--bold data-v-baa6e4ef"
          >{{e}} {{f}}</text
        ></view
      ><view class="summary-row data-v-baa6e4ef"
        ><text class="summary-label data-v-baa6e4ef">就诊人</text
        ><text class="summary-value data-v-baa6e4ef">{{patientName}}</text></view
      ><view wx:if="{{requireDeposit}}" class="summary-row data-v-baa6e4ef"
        ><text class="summary-label data-v-baa6e4ef">定金</text
        ><text class="summary-value summary-value--price data-v-baa6e4ef">¥{{depositAmount}}</text></view
      ><view class="summary-row data-v-baa6e4ef"
        ><text class="summary-label data-v-baa6e4ef">挂号费</text
        ><text class="summary-value summary-value--price data-v-baa6e4ef">¥{{consultFee}}</text></view
      ><view class="summary-row data-v-baa6e4ef"
        ><text class="summary-label data-v-baa6e4ef">病症描述</text
        ><text class="summary-value data-v-baa6e4ef">{{symptomDesc}}</text></view
      ></view
    ><view class="visit-notice-card data-v-baa6e4ef"
      ><view class="visit-notice-header data-v-baa6e4ef"
        ><text class="visit-notice-header-icon data-v-baa6e4ef">⚠</text><text class="visit-notice-title data-v-baa6e4ef">就诊须知</text></view
      ><view class="visit-notice-item data-v-baa6e4ef"
        ><text class="visit-notice-index data-v-baa6e4ef">1.</text><text class="visit-notice-text data-v-baa6e4ef">请携带既往病历与阻鼾器</text></view
      ><view class="visit-notice-item data-v-baa6e4ef"
        ><text class="visit-notice-index data-v-baa6e4ef">2.</text><text class="visit-notice-text data-v-baa6e4ef">提前15分钟到达诊所签到</text></view
      ><view class="visit-notice-item data-v-baa6e4ef"
        ><text class="visit-notice-index data-v-baa6e4ef">3.</text><text class="visit-notice-text data-v-baa6e4ef">如需取消，请最晚于{{g}}操作</text></view
      ><view class="visit-notice-item data-v-baa6e4ef"
        ><text class="visit-notice-index data-v-baa6e4ef">4.</text><text class="visit-notice-text data-v-baa6e4ef">首次就诊需完成睡眠评估</text></view
      ></view
    ><view class="actions data-v-baa6e4ef"
      ><hj-button
        wx:if="{{i}}"
        class="data-v-baa6e4ef"
        u-s="{{['d']}}"
        bindclick="{{h}}"
        u-i="baa6e4ef-1"
        bind:__l="__l"
        u-p="{{i}}"
        >查看预约详情</hj-button
      ><hj-button
        wx:if="{{k}}"
        class="data-v-baa6e4ef"
        u-s="{{['d']}}"
        bindclick="{{j}}"
        u-i="baa6e4ef-2"
        bind:__l="__l"
        u-p="{{k}}"
        >返回首页</hj-button
      ></view
    ><view class="remind data-v-baa6e4ef"
      ><view class="remind-item data-v-baa6e4ef"
        ><image class="remind-icon data-v-baa6e4ef" src="/static/icons/bell.svg" /><text class="remind-text data-v-baa6e4ef"
          >就诊当天将通过微信消息提醒您</text
        ></view
      ></view
    ></view
  ></view
>
