.data-v-7e5a1194:root {
  --color-primary-50: #eef4ff;
  --color-primary-100: #d9e6ff;
  --color-primary-300: #8eafff;
  --color-primary-500: #3b6bf5;
  --color-primary-600: #2a52d4;
  --color-primary-800: #1a3580;
  --color-secondary-100: #d3f5e3;
  --color-secondary-500: #1a9d5c;
  --color-success-500: #22c55e;
  --color-warning-500: #f59e0b;
  --color-error-500: #ef4444;
  --color-gold-400: #f5a623;
  --color-gray-50: #f9fafb;
  --color-gray-100: #f3f4f6;
  --color-gray-200: #e5e7eb;
  --color-gray-300: #d1d5db;
  --color-gray-400: #9ca3af;
  --color-gray-500: #6b7280;
  --color-gray-600: #4b5563;
  --color-gray-700: #374151;
  --color-gray-800: #1f2937;
  --color-gray-900: #111827;
  --gradient-primary: linear-gradient(
    135deg,
    #3b6bf5 0%,
    #5a85f5 50%,
    #8eafff 100%
  );
  --gradient-success: linear-gradient(135deg, #10b981 0%, #059669 100%);
  --gradient-danger: linear-gradient(135deg, #f87171 0%, #ef4444 100%);
  --gradient-warning: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
  
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 20px;
  --radius-full: 9999px;
  --shadow-sm: 0 2px 4px rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.06);
  --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.08);
  --safe-bottom: env(safe-area-inset-bottom, 34px);
}

.page.data-v-7e5a1194 {
  min-height: 100vh;
  background: #f4f6fa;
  padding-bottom: calc(100px + var(--safe-bottom));
  box-sizing: border-box;
}

.page-content.data-v-7e5a1194 {
  padding: 16px;
}

/* 1. Status Hero Banner */
.status-hero.data-v-7e5a1194 {
  border-radius: var(--radius-xl);
  padding: 24px 20px;
  margin-bottom: 16px;
  color: #ffffff;
  box-shadow: 0 8px 20px rgba(59, 107, 245, 0.15);
  background: var(--gradient-primary);
  position: relative;
  overflow: hidden;
}

.status-hero.status--confirmed.data-v-7e5a1194,
.status-hero.status--reminded.data-v-7e5a1194 {
  background: var(--gradient-primary);
  box-shadow: 0 8px 20px rgba(59, 107, 245, 0.18);
}

.status-hero.status--completed.data-v-7e5a1194,
.status-hero.status--checked_in.data-v-7e5a1194 {
  background: var(--gradient-success);
  box-shadow: 0 8px 20px rgba(16, 185, 129, 0.18);
}

.status-hero.status--cancelled.data-v-7e5a1194,
.status-hero.status--no_show.data-v-7e5a1194,
.status-hero.status--arrived.data-v-7e5a1194 {
  background: linear-gradient(135deg, #9ca3af 0%, #6b7280 100%) !important;
  box-shadow: 0 8px 20px rgba(107, 114, 128, 0.15) !important;
}

.status-hero.status--pending.data-v-7e5a1194 {
  background: var(--gradient-success);
  box-shadow: 0 8px 20px rgba(16, 185, 129, 0.18);
}

.status-hero-main.data-v-7e5a1194 {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 2;
}

.status-icon-wrapper.data-v-7e5a1194 {
  width: 48px;
  height: 48px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16px;
  flex-shrink: 0;
  backdrop-filter: blur(5px);
}

.status-icon.data-v-7e5a1194 {
  width: 24px;
  height: 24px;
  filter: brightness(0) invert(1);
}

.status-title-group.data-v-7e5a1194 {
  display: flex;
  flex-direction: column;
}

.status-title.data-v-7e5a1194 {
  font-size: 20px;
  font-weight: 700;
  letter-spacing: 0.5px;
  margin-bottom: 4px;
}

.status-desc.data-v-7e5a1194 {
  font-size: 12px;
  opacity: 0.9;
  line-height: 1.4;
}

/* 2. Order No Bar */
.order-no-bar.data-v-7e5a1194 {
  background: #ffffff;
  border-radius: var(--radius-md);
  padding: 12px 16px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: var(--shadow-sm);
}

.no-text-group.data-v-7e5a1194 {
  display: flex;
  align-items: center;
}

.no-label.data-v-7e5a1194 {
  font-size: 13px;
  color: #6b7280;
  margin-right: 8px;
}

.no-value.data-v-7e5a1194 {
  font-size: 13px;
  font-weight: 600;
  color: #1f2937;
  font-family: SF Mono, monospace;
}

.copy-btn-action.data-v-7e5a1194 {
  margin: 0;
  padding: 0;
  width: 52px;
  height: 24px;
  line-height: 22px;
  font-size: 11px;
  font-weight: 500;
  color: #3b6bf5;
  background: rgba(59, 107, 245, 0.08);
  border: 1px solid rgba(59, 107, 245, 0.15);
  border-radius: 6px;
  text-align: center;
  box-sizing: border-box;
}

.copy-btn-hover.data-v-7e5a1194 {
  background: rgba(59, 107, 245, 0.15);
}

/* 3. Doctor Details Card */
.card-premium.data-v-7e5a1194 {
  background: #ffffff;
  border-radius: var(--radius-lg);
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: var(--shadow-md);
}

.card-premium.doctor-card.data-v-7e5a1194 {
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: var(--card-shadow);
  border-radius: 16px;
}

.doctor-card.data-v-7e5a1194 {
  display: flex;
  align-items: center;
}

.doc-avatar-large.data-v-7e5a1194 {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b6bf5 0%, #8eafff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  position: relative;
  flex-shrink: 0;
}

.doc-avatar-text-large.data-v-7e5a1194 {
  color: #ffffff;
  font-size: 22px;
  font-weight: 700;
  z-index: 2;
}

.doc-info-detail.data-v-7e5a1194 {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.doc-name-row.data-v-7e5a1194 {
  display: flex;
  align-items: center;
  margin-bottom: 4px;
}

.doc-name-large.data-v-7e5a1194 {
  font-size: 17px;
  font-weight: 600;
  color: #1f2937;
  margin-right: 8px;
}

.doc-title-badge.data-v-7e5a1194 {
  font-size: 11px;
  color: #3b6bf5;
  background: #eef4ff;
  padding: 2px 6px;
  border-radius: 4px;
  font-weight: 500;
  line-height: 1;
  display: inline-block;
}

.doc-dept.data-v-7e5a1194 {
  font-size: 13px;
  color: #6b7280;
  margin-bottom: 6px;
  display: block;
}

.doctor-expertise.data-v-7e5a1194 {
  display: flex;
  gap: 4px;
  flex-wrap: wrap;
  margin-top: 4px;
}

.doctor-expertise-tag.data-v-7e5a1194 {
  font-size: 11px;
  color: #1a9d5c;
  background: #d3f5e3;
  padding: 2px 6px;
  border-radius: 4px;
  line-height: 1.2;
}

/* 4. Schedule & Location Card */
.card-header-premium.data-v-7e5a1194 {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f3f4f6;
}

.header-icon.data-v-7e5a1194 {
  width: 18px;
  height: 18px;
  margin-right: 8px;
  filter: brightness(0) saturate(100%) invert(37%) sepia(89%) saturate(2255%) hue-rotate(213deg) brightness(98%) contrast(94%);
}

.header-title.data-v-7e5a1194 {
  font-size: 15px;
  font-weight: 700;
  color: #1f2937;
}

.detail-rows.data-v-7e5a1194 {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.detail-row.data-v-7e5a1194 {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.detail-row.detail-row--clickable.data-v-7e5a1194:active {
  opacity: 0.7;
}

.row-value-group.data-v-7e5a1194 {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
}

.nav-icon.data-v-7e5a1194 {
  width: 14px;
  height: 14px;
  margin-left: 6px;
  flex-shrink: 0;
}

.row-label.data-v-7e5a1194 {
  font-size: 13px;
  color: #9ca3af;
  flex-shrink: 0;
  width: 72px;
}

.row-value.data-v-7e5a1194 {
  font-size: 13px;
  color: #374151;
  text-align: right;
  flex: 1;
}

.row-value--bold.data-v-7e5a1194 {
  font-weight: 700;
  color: #3b6bf5;
}

.row-value--small.data-v-7e5a1194 {
  font-size: 12px;
  color: #6b7280;
  line-height: 1.4;
}

/* 5. Symptom card styles */
.symptom-card.data-v-7e5a1194 {
  border-left: 4px solid #3b6bf5;
}

.symptom-content-wrapper.data-v-7e5a1194 {
  background: #f8fafc;
  padding: 12px 16px;
  border-radius: var(--radius-sm);
  margin-top: 4px;
}

.symptom-text-styled.data-v-7e5a1194 {
  font-size: 13px;
  color: #374151;
  line-height: 1.6;
  text-align: left;
  display: block;
}

/* 6. Cancel card styles */
.cancel-card-styled.data-v-7e5a1194 {
  border-left: 4px solid #ef4444;
}

.cancel-content-wrapper.data-v-7e5a1194 {
  background: rgba(239, 68, 68, 0.03);
  border: 1px solid rgba(239, 68, 68, 0.08);
  padding: 12px 16px;
  border-radius: var(--radius-sm);
  margin-top: 4px;
}

.cancel-text-styled.data-v-7e5a1194 {
  font-size: 13px;
  color: #ef4444;
  line-height: 1.6;
}

/* 7. Action Footer Panel */
.action-footer.data-v-7e5a1194 {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 16px 20px calc(16px + var(--safe-bottom));
  box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.04);
  display: flex;
  gap: 12px;
  z-index: 10;
}

.footer-btn.data-v-7e5a1194 {
  flex: 1;
  height: 46px;
  line-height: 44px;
  font-size: 14px;
  font-weight: 600;
  border-radius: 23px;
  text-align: center;
  box-sizing: border-box;
}

.btn-ghost.data-v-7e5a1194 {
  color: #3b6bf5;
  background: #ffffff;
  border: 1.5px solid #3b6bf5;
}

.btn-danger-ghost.data-v-7e5a1194 {
  color: #ef4444;
  background: #ffffff;
  border: 1.5px solid #ef4444;
}

.btn-primary-full.data-v-7e5a1194 {
  color: #ffffff;
  background: var(--gradient-primary);
  box-shadow: 0 4px 12px rgba(59, 107, 245, 0.2);
}

.footer-btn-hover.data-v-7e5a1194 {
  opacity: 0.85;
}

/* 8. Notice Warning Card */
.notice-card-warning.data-v-7e5a1194 {
  background: #fffbeb !important;
  border: 1px solid #fde68a !important;
  border-radius: 12px;
  padding: 12px 16px;
  margin: 0 0 16px 0;
  box-shadow: 0 2px 8px rgba(245, 158, 11, 0.05);
}

.notice-content-wrapper.data-v-7e5a1194 {
  display: flex;
  align-items: center;
  gap: 8px;
}

.notice-icon.data-v-7e5a1194 {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
}

.notice-text-warning.data-v-7e5a1194 {
  font-size: 13px;
  color: #b45309;
  line-height: 1.5;
  font-weight: 500;
}
.visit-notice-card.data-v-7e5a1194 {
  background: #fffaf0;
  border: 1px solid #fde6b8;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
}
.visit-notice-header.data-v-7e5a1194 {
  display: flex;
  align-items: center;
  margin-bottom: 10px;
}
.visit-notice-header-icon.data-v-7e5a1194 {
  width: 18px;
  margin-right: 6px;
  color: #f59e0b;
  font-size: 15px;
  line-height: 1;
}
.visit-notice-title.data-v-7e5a1194 {
  font-size: 14px;
  font-weight: 600;
  color: #d97706;
}
.visit-notice-item.data-v-7e5a1194 {
  display: flex;
  align-items: flex-start;
  padding: 4px 0;
}
.visit-notice-index.data-v-7e5a1194 {
  width: 16px;
  margin-right: 4px;
  flex-shrink: 0;
  font-size: 13px;
  font-weight: normal;
  color: #4b5563;
  line-height: 1.5;
}
.visit-notice-text.data-v-7e5a1194 {
  flex: 1;
  font-size: 13px;
  font-weight: normal;
  color: #4b5563;
  line-height: 1.5;
}
.inline-submit-btn.data-v-7e5a1194 {
  margin-top: 14px;
  height: 42px;
  line-height: 40px;
  border-radius: 21px;
  background: #3b6bf5;
  color: #fff;
  font-size: 14px;
  font-weight: 600;
}
.rating-row.data-v-7e5a1194 {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}
.rating-star.data-v-7e5a1194 {
  font-size: 28px;
  color: #d1d5db;
  line-height: 1;
}
.rating-star--active.data-v-7e5a1194 {
  color: #f59e0b;
}
.eval-textarea.data-v-7e5a1194 {
  width: 100%;
  min-height: 96px;
  background: #f9fafb;
  border: 1px solid #e5e7eb;
  border-radius: 12px;
  padding: 12px;
  font-size: 14px;
  color: #374151;
  box-sizing: border-box;
}
