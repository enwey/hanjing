<view class="page data-v-6a5afdbe">
  <hj-navbar title="分销中心" show-back="{{true}}" />

  <view class="banner data-v-6a5afdbe">
    <view class="banner-bg data-v-6a5afdbe"></view>
    <view class="banner-content data-v-6a5afdbe">
      <text class="banner-title data-v-6a5afdbe">我的推广</text>
      <view class="banner-stats data-v-6a5afdbe">
        <view class="stat-item data-v-6a5afdbe">
          <text class="stat-val data-v-6a5afdbe">{{a}}</text>
          <text class="stat-label data-v-6a5afdbe">累计佣金</text>
        </view>
        <view class="stat-divider data-v-6a5afdbe"></view>
        <view class="stat-item data-v-6a5afdbe">
          <text class="stat-val highlight data-v-6a5afdbe">{{b}}</text>
          <text class="stat-label data-v-6a5afdbe">可提现</text>
        </view>
        <view class="stat-divider data-v-6a5afdbe"></view>
        <view class="stat-item data-v-6a5afdbe">
          <text class="stat-val data-v-6a5afdbe">{{c}}</text>
          <text class="stat-label data-v-6a5afdbe">团队成员</text>
        </view>
      </view>
    </view>
  </view>

  <view class="actions data-v-6a5afdbe">
    <view
      wx:for="{{d}}"
      wx:for-item="action"
      wx:key="c"
      class="action-item data-v-6a5afdbe"
      bindtap="{{action.d}}"
    >
      <view class="action-icon data-v-6a5afdbe">
        <image class="action-icon-image data-v-6a5afdbe" src="{{action.a}}" mode="aspectFit" />
      </view>
      <text class="action-label data-v-6a5afdbe">{{action.b}}</text>
    </view>
  </view>

  <view class="section data-v-6a5afdbe">
    <view class="section-hd data-v-6a5afdbe">
      <text class="section-title data-v-6a5afdbe">近期推广订单</text>
      <text class="section-more data-v-6a5afdbe" bindtap="{{e}}">全部</text>
    </view>
    <view class="order-list data-v-6a5afdbe">
      <view
        wx:for="{{f}}"
        wx:for-item="order"
        wx:key="i"
        class="order-item data-v-6a5afdbe"
      >
        <image
          wx:if="{{!order.b}}"
          class="order-img data-v-6a5afdbe"
          src="{{order.a}}"
          mode="aspectFill"
        />
        <view wx:else class="order-placeholder data-v-6a5afdbe">
          <image class="order-placeholder-icon data-v-6a5afdbe" src="/static/icons/distribution.svg" mode="aspectFit" />
        </view>
        <view class="order-info data-v-6a5afdbe">
          <text class="order-name data-v-6a5afdbe">{{order.c}}</text>
          <text class="order-meta data-v-6a5afdbe">{{order.d}} | {{order.e}}</text>
        </view>
        <view class="order-amount data-v-6a5afdbe">
          <text class="amount-val data-v-6a5afdbe">+{{order.f}}</text>
          <text class="{{['amount-tag', 'data-v-6a5afdbe', order.h]}}">{{order.g}}</text>
        </view>
      </view>
      <hj-empty
        wx:if="{{g}}"
        class="data-v-6a5afdbe"
        u-i="6a5afdbe-0"
        bind:__l="__l"
        u-p="{{h}}"
      />
    </view>
  </view>

  <view class="section data-v-6a5afdbe">
    <view class="rule-entry data-v-6a5afdbe" bindtap="{{i}}">
      <text class="data-v-6a5afdbe">分销规则与说明</text>
      <text class="arrow data-v-6a5afdbe">&gt;</text>
    </view>
  </view>
</view>
