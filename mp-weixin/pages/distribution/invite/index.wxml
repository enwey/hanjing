<view class="page data-v-466378e0">
  <hj-navbar title="邀请好友" show-back="{{true}}" />

  <view class="content data-v-466378e0">
    <view class="banner data-v-466378e0">
      <view class="banner-glow data-v-466378e0"></view>
      <view class="banner-content data-v-466378e0">
        <text class="banner-title data-v-466378e0">邀请好友，一起赚钱</text>
        <text class="banner-desc data-v-466378e0">分享专属海报给好友，好友完成下单后，系统会自动记录邀请关系并结算推广佣金。</text>
        <view class="banner-tags data-v-466378e0">
          <text class="banner-tag data-v-466378e0" bindtap="{{b}}">复制邀请码</text>
          <text class="banner-tag data-v-466378e0">绑定关系</text>
          <text class="banner-tag data-v-466378e0">下单后计佣</text>
        </view>
      </view>
    </view>

    <view class="poster-section data-v-466378e0">
      <view class="poster-section-header data-v-466378e0">
        <text class="section-title data-v-466378e0">推广海报</text>
      </view>
      <text class="section-subtitle data-v-466378e0">保存后可直接发好友或朋友圈</text>
      <view wx:if="{{c}}" class="poster-tip-card data-v-466378e0">
        <image class="poster-tip-icon data-v-466378e0" src="/static/icons/info.svg" mode="aspectFit" />
        <text class="poster-tip data-v-466378e0">{{d}}</text>
      </view>
      <view class="poster-preview data-v-466378e0">
        <view class="poster data-v-466378e0">
          <view class="poster-wave data-v-466378e0"></view>
          <text class="poster-top data-v-466378e0">鼾静健康 · 睡眠评估与治疗</text>
          <view class="poster-body data-v-466378e0">
            <view class="poster-copy data-v-466378e0">
              <text class="poster-kicker data-v-466378e0">AI SLEEP CARE</text>
              <text class="poster-slogan data-v-466378e0">告别打鼾</text>
              <text class="poster-slogan soft data-v-466378e0">让每一晚都睡得安稳</text>
            </view>
            <view class="poster-qr data-v-466378e0">
              <image wx:if="{{g}}" class="poster-qr-image data-v-466378e0" src="{{h}}" mode="aspectFill" />
              <view wx:else class="poster-code-box data-v-466378e0">
                <text class="poster-code-label data-v-466378e0">邀请码</text>
                <text class="poster-code-value data-v-466378e0">{{f}}</text>
              </view>
            </view>
            <view class="poster-invite-chip data-v-466378e0">
              <text class="poster-invite-chip-text data-v-466378e0">您的专属邀请码：{{a}}</text>
            </view>
          </view>
          <text class="poster-bottom data-v-466378e0">保存或分享海报给好友或发布朋友圈</text>
        </view>
      </view>
    </view>

    <view class="steps data-v-466378e0">
      <view class="guide-title data-v-466378e0">如何推广</view>
      <view class="steps-flow data-v-466378e0">
        <view class="step-line-vertical data-v-466378e0"></view>

        <view class="step-item data-v-466378e0">
          <view class="step-num data-v-466378e0">01</view>
          <view class="step-info data-v-466378e0">
            <text class="step-title data-v-466378e0">分享邀请海报</text>
            <text class="step-desc data-v-466378e0">保存专属海报到相册发送给好友或分享给好友或发布朋友圈</text>
          </view>
        </view>

        <view class="step-item data-v-466378e0">
          <view class="step-num data-v-466378e0">02</view>
          <view class="step-info data-v-466378e0">
            <text class="step-title data-v-466378e0">绑定关系</text>
            <text class="step-desc data-v-466378e0">好友微信通过海报/小程序码登录，自动锁定并绑定关系</text>
          </view>
        </view>

        <view class="step-item data-v-466378e0">
          <view class="step-num data-v-466378e0">03</view>
          <view class="step-info data-v-466378e0">
            <text class="step-title data-v-466378e0">下单后计佣</text>
            <text class="step-desc data-v-466378e0">受邀好友后续在小程序完成下单，系统将实时为您结算发放推广佣金</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-action-bar data-v-466378e0">
    <view class="pa-btn secondary data-v-466378e0" bindtap="{{i}}">
      <image class="pa-btn-icon data-v-466378e0" src="/static/icons/poster-save.svg" mode="aspectFit" />
      <text class="pa-btn-text data-v-466378e0">保存海报</text>
    </view>
    <button class="pa-btn share data-v-466378e0" open-type="share">
      <image class="pa-btn-icon white data-v-466378e0" src="/static/icons/paper-plane.svg" mode="aspectFit" />
      <text class="pa-btn-text data-v-466378e0">分享好友</text>
    </button>
  </view>

  <canvas canvas-id="distributionInvitePoster" class="poster-canvas data-v-466378e0"></canvas>
</view>
