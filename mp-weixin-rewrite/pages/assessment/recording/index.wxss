.recording-page { min-height: 100vh; background: radial-gradient(circle at 90% 10%, rgba(59,107,245,0.18), transparent 45%), radial-gradient(circle at 10% 60%, rgba(139,92,246,0.15), transparent 45%), #050714; }
.page-content { padding: 0 24rpx 24rpx; display: flex; flex-direction: column; min-height: calc(100vh - 88rpx); }
.member-picker { margin-top: 20rpx; padding: 22rpx 24rpx; border-radius: 24rpx; background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.08); }
.member-picker-content { display: flex; justify-content: space-between; align-items: center; }
.member-info { display: flex; gap: 8rpx; font-size: 24rpx; }
.member-label { color: rgba(224,231,255,0.66); }
.member-value { color: #8eafff; font-weight: 700; }
.member-action { display: flex; align-items: center; gap: 4rpx; }
.member-action-text { font-size: 24rpx; color: rgba(224,231,255,0.72); }
.member-action-arrow { width: 24rpx; height: 24rpx; transform: rotate(90deg); }
.guide-card { padding: 24rpx 20rpx 8rpx; text-align: center; }
.guide-emoji { display: block; font-size: 44rpx; margin-bottom: 8rpx; }
.guide-title { display: block; font-size: 34rpx; font-weight: 700; color: #e2e8f0; }
.guide-desc { display: block; margin-top: 8rpx; font-size: 24rpx; line-height: 1.6; color: rgba(224,231,255,0.65); }
.record-area { display: flex; flex: 1; flex-direction: column; align-items: center; justify-content: center; }
.waveform { display: flex; align-items: center; gap: 8rpx; height: 80rpx; margin-bottom: 20rpx; }
.wave-bar { width: 10rpx; border-radius: 9999rpx; background: linear-gradient(180deg, #8eafff, #3b6bf5); box-shadow: 0 0 14rpx rgba(59,107,245,0.5); }
.record-time { font-size: 56rpx; letter-spacing: 6rpx; color: #e0e7ff; font-family: SF Mono, Menlo, monospace; }
.mic-btn { width: 156rpx; height: 156rpx; margin-top: 18rpx; border-radius: 9999rpx; background: linear-gradient(135deg, #7c3aed, #4f46e5); display: flex; align-items: center; justify-content: center; box-shadow: 0 16rpx 40rpx rgba(124,58,237,0.35); border: 4rpx solid rgba(255,255,255,0.15); }
.mic-btn--recording { background: linear-gradient(135deg, #ef4444, #dc2626); box-shadow: 0 16rpx 40rpx rgba(239,68,68,0.45); }
.mic-btn--paused { background: linear-gradient(135deg, #f59e0b, #d97706); box-shadow: 0 16rpx 40rpx rgba(245,158,11,0.4); }
.mic-icon { font-size: 54rpx; color: #ffffff; }
.status-text { margin-top: 24rpx; font-size: 26rpx; color: rgba(224,231,255,0.7); }
.actions { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.btn { flex: 1; min-height: 88rpx; display: flex; align-items: center; justify-content: center; border-radius: 9999rpx; font-size: 28rpx; font-weight: 700; }
.btn--ghost { background: rgba(255,255,255,0.1); color: #e2e8f0; border: 1rpx solid rgba(255,255,255,0.12); }
.btn--primary { background: linear-gradient(135deg, #3b6bf5, #6366f1); color: #ffffff; box-shadow: 0 10rpx 26rpx rgba(59,107,245,0.24); }
.tips-card { padding: 24rpx; border-radius: 24rpx; background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.08); }
.tips-title { display: block; margin-bottom: 14rpx; font-size: 28rpx; font-weight: 700; color: #ffffff; }
.tips-list { display: flex; flex-direction: column; gap: 10rpx; }
.tip-item { font-size: 24rpx; line-height: 1.65; color: rgba(224,231,255,0.72); }
.analyzing-screen { min-height: calc(100vh - 88rpx); display: flex; align-items: center; justify-content: center; padding: 24rpx; }
.analyzing-card { width: 100%; max-width: 520rpx; padding: 56rpx 40rpx; border-radius: 32rpx; background: rgba(255,255,255,0.08); border: 1rpx solid rgba(255,255,255,0.08); text-align: center; }
.spinner { width: 76rpx; height: 76rpx; margin: 0 auto 24rpx; border-radius: 9999rpx; border: 6rpx solid rgba(255,255,255,0.2); border-top-color: #8eafff; animation: spin 1s linear infinite; }
.analyzing-text { display: block; font-size: 34rpx; font-weight: 700; color: #ffffff; }
.analyzing-hint { display: block; margin-top: 12rpx; font-size: 24rpx; color: rgba(224,231,255,0.72); }
@keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
