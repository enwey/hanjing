.assessment-page { min-height: 100vh; padding-bottom: 32rpx; background: linear-gradient(180deg, #f0f5ff 0, #f7f8fb 220rpx, #f7f8fb 100%); }
.hero-card { margin: 24rpx; padding: 34rpx 28rpx; border-radius: 34rpx; background: linear-gradient(135deg, #2457e6 0%, #4c80ff 52%, #739eff 100%); box-shadow: 0 20rpx 48rpx rgba(36, 87, 230, 0.22); }
.hero-card__eyebrow { display: block; font-size: 20rpx; letter-spacing: 3rpx; color: rgba(255, 255, 255, 0.76); }
.hero-card__title { display: block; margin-top: 18rpx; font-size: 42rpx; font-weight: 700; line-height: 1.3; color: #ffffff; }
.hero-card__desc { display: block; margin-top: 16rpx; font-size: 25rpx; line-height: 1.7; color: rgba(255, 255, 255, 0.88); }
.section-heading { margin-bottom: 22rpx; }
.section-heading__title { display: block; font-size: 32rpx; font-weight: 700; color: #111827; }
.section-heading__desc { display: block; margin-top: 8rpx; font-size: 24rpx; line-height: 1.6; color: #6b7280; }
.assessment-card-list, .record-list { display: flex; flex-direction: column; gap: 18rpx; }
.assessment-card { display: flex; align-items: flex-start; gap: 20rpx; padding: 24rpx; border-radius: 24rpx; background: linear-gradient(180deg, #fbfcff 0%, #f1f6ff 100%); border: 1rpx solid #dbe7ff; }
.assessment-card__icon { width: 56rpx; height: 56rpx; flex-shrink: 0; }
.assessment-card__content { flex: 1; min-width: 0; }
.assessment-card__top { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.assessment-card__title { flex: 1; font-size: 30rpx; font-weight: 700; color: #111827; }
.assessment-card__tag { flex-shrink: 0; padding: 8rpx 16rpx; border-radius: 999rpx; background: #ffffff; font-size: 20rpx; color: #2457e6; }
.assessment-card__desc { display: block; margin-top: 12rpx; font-size: 24rpx; line-height: 1.6; color: #6b7280; }
.record-card { padding: 24rpx; border-radius: 24rpx; background: #ffffff; border: 1rpx solid #edf2fb; }
.record-card__top { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.record-card__type { font-size: 28rpx; font-weight: 700; color: #111827; }
.record-card__level { font-size: 24rpx; font-weight: 700; }
.record-card__summary { display: block; margin-top: 14rpx; font-size: 25rpx; line-height: 1.6; color: #374151; }
.record-card__recommendation { display: block; margin-top: 10rpx; font-size: 23rpx; line-height: 1.7; color: #6b7280; }
.record-card__date { display: block; margin-top: 14rpx; font-size: 22rpx; color: #9ca3af; }
.empty-card, .state-card { padding: 28rpx; border-radius: 24rpx; background: #f9fafb; }
.empty-card__title { display: block; font-size: 30rpx; font-weight: 700; color: #111827; }
.empty-card__desc, .state-text { display: block; margin-top: 12rpx; font-size: 24rpx; line-height: 1.6; color: #6b7280; }
.empty-card__button { margin-top: 22rpx; height: 78rpx; line-height: 78rpx; border-radius: 999rpx; background: #2457e6; color: #ffffff; font-size: 26rpx; font-weight: 700; }
.empty-card__button::after { border: 0; }
