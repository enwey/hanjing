<view class="result-page">
  <hj-navbar title="评估结果" showBack="{{true}}" bindback="handleBack" />

  <view class="page-content">
    <view wx:if="{{isLoading}}" class="empty-state">
      <text class="empty-desc">正在加载评估结果...</text>
    </view>

    <view wx:elif="{{hasLoaded && !resultDetail}}" class="empty-state">
      <view class="empty-icon-img" style="-webkit-mask-image: url(/static/icons/report.svg); mask-image: url(/static/icons/report.svg); background-color: #94a3b8;"></view>
      <text class="empty-title">暂无评估结果</text>
      <text class="empty-desc">请先完成 ESS 嗜睡量表评估</text>
      <view class="btn-retake" bindtap="restartAssessment">开始评估</view>
    </view>

    <block wx:else>
      <view class="score-card" style="background: {{levelInfo.color}}">
        <text class="score-label">ESS 评分</text>
        <text class="score-value">{{score}}</text>
        <text class="score-unit">/ 24 分</text>
        <text class="score-level">{{levelInfo.level}}</text>
      </view>

      <view class="result-card">
        <view class="result-title-container">
          <view class="title-icon" style="-webkit-mask-image: url(/static/icons/trend.svg); mask-image: url(/static/icons/trend.svg); background-color: #3b6bf5;"></view>
          <text class="result-title">评分解读</text>
        </view>
        <text class="result-desc">{{levelInfo.desc}}</text>
      </view>

      <view class="result-card">
        <view class="result-title-container">
          <view class="title-icon" style="-webkit-mask-image: url(/static/icons/report.svg); mask-image: url(/static/icons/report.svg); background-color: #3b6bf5;"></view>
          <text class="result-title">答案回顾</text>
        </view>
        <view class="answer-list">
          <view wx:for="{{answerReviewList}}" wx:key="questionId" class="answer-item">
            <text class="answer-q">第{{item.index}}题. {{item.situation}}</text>
            <text class="answer-s" style="{{item.style}}">{{item.label}}</text>
          </view>
        </view>
      </view>

      <view class="advice-card" style="background: {{levelInfo.adviceBg}}; border-color: {{levelInfo.adviceBorder}}">
        <view class="advice-header-container">
          <view class="advice-icon-img" style="-webkit-mask-image: url({{levelInfo.adviceIcon}}); mask-image: url({{levelInfo.adviceIcon}}); background-color: {{levelInfo.adviceTitleColor}};"></view>
          <text class="advice-title" style="color: {{levelInfo.adviceTitleColor}}">专业建议</text>
        </view>
        <text class="advice-text" style="color: {{levelInfo.adviceTextColor}}">{{levelInfo.advice}}</text>
      </view>

      <view class="action-buttons">
        <view class="btn-primary" bindtap="goAppointment">立即预约门诊</view>
        <view class="btn-secondary" bindtap="goHome">返回睡眠评估</view>
        <view class="btn-outline" bindtap="restartAssessment">重新评估</view>
      </view>
    </block>
  </view>
</view>
