<view class="container distribution-products-page">
  <hj-navbar title="推广商品" showBack="{{true}}" />

  <view class="page-section state-card" wx:if="{{loading}}">
    <text class="page-description">正在加载推广商品...</text>
  </view>

  <view class="page-section state-card" wx:elif="{{loadError}}">
    <text class="state-title">加载失败</text>
    <text class="page-description">{{loadError}}</text>
  </view>

  <view class="page-section state-card" wx:elif="{{!products.length}}">
    <text class="state-title">暂无推广商品</text>
  </view>

  <block wx:else>
    <view class="page-section summary-bar">
      <view class="summary-item">
        <text class="summary-item__value">{{summary.productCount}}</text>
        <text class="summary-item__label">可推广商品</text>
      </view>
      <view class="summary-item" wx:if="{{summary.averageCommissionRate}}">
        <text class="summary-item__value">{{summary.averageCommissionRate}}</text>
        <text class="summary-item__label">平均佣金比例</text>
      </view>
      <view class="summary-item" wx:if="{{summary.highestCommissionLabel}}">
        <text class="summary-item__value">{{summary.highestCommissionLabel}}</text>
        <text class="summary-item__label">最高预计佣金</text>
      </view>
    </view>

    <view class="page-section">
    <view class="product-list">
      <view wx:for="{{products}}" wx:key="id" class="product-card" data-id="{{item.id}}" bindtap="openProductDetail">
        <view class="product-card__cover">
          <image wx:if="{{item.image}}" src="{{item.image}}" mode="aspectFill" class="product-card__cover-image" />
          <view wx:else class="product-card__placeholder">
            <image src="/static/icons/distribution.svg" mode="aspectFit" class="product-card__placeholder-icon" />
          </view>
        </view>
        <view class="product-card__body">
          <text class="product-card__name">{{item.name}}</text>
          <text class="product-card__meta">售价 {{item.priceLabel}}</text>
          <text wx:if="{{item.commissionRateLabel}}" class="product-card__meta">佣金比例 {{item.commissionRateLabel}}</text>
          <text wx:if="{{item.commissionAmountLabel}}" class="product-card__commission">预计佣金 {{item.commissionAmountLabel}}</text>
        </view>
      </view>
    </view>
    </view>
  </block>
</view>
