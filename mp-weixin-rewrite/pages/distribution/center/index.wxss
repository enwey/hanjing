.distribution-center-page { background: #f9fafb; padding-bottom: 40rpx; }
.state-card { text-align: center; }
.state-title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.distribution-banner { background: linear-gradient(135deg, #2456d7 0%, #5c96ff 100%); color: #ffffff; }
.distribution-banner__title { display: block; font-size: 34rpx; font-weight: 700; }
.distribution-banner__stats { display: flex; gap: 20rpx; margin-top: 28rpx; }
.distribution-banner__stat { flex: 1; }
.distribution-banner__value { display: block; font-size: 34rpx; font-weight: 700; }
.distribution-banner__value--highlight { color: #fff3bf; }
.distribution-banner__label { display: block; margin-top: 10rpx; font-size: 24rpx; opacity: 0.9; }
.action-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 18rpx; }
.action-card { display: flex; flex-direction: column; align-items: center; gap: 14rpx; padding: 12rpx 0; }
.action-card__icon-wrap { width: 84rpx; height: 84rpx; border-radius: 24rpx; background: linear-gradient(135deg, #eef4ff 0%, #dbeafe 100%); display: flex; align-items: center; justify-content: center; }
.action-card__icon { width: 40rpx; height: 40rpx; }
.action-card__label { font-size: 24rpx; color: #1f2937; }
.section-header { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: 700; color: #1f2937; }
.section-more { font-size: 24rpx; color: #3b6bf5; }
.distribution-order-list { display: flex; flex-direction: column; gap: 20rpx; }
.distribution-order-card { display: flex; gap: 20rpx; align-items: center; }
.distribution-order-card__cover { width: 120rpx; height: 120rpx; border-radius: 20rpx; overflow: hidden; background: #eef2f7; flex-shrink: 0; }
.distribution-order-card__cover-image { width: 100%; height: 100%; }
.distribution-order-card__placeholder { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #e8efff 0%, #f2f6ff 100%); }
.distribution-order-card__placeholder-icon { width: 44rpx; height: 44rpx; }
.distribution-order-card__body { flex: 1; min-width: 0; }
.distribution-order-card__title { display: block; font-size: 28rpx; font-weight: 700; color: #1f2937; }
.distribution-order-card__meta { display: block; margin-top: 10rpx; font-size: 24rpx; color: #6b7280; }
.distribution-order-card__amount { display: flex; flex-direction: column; align-items: flex-end; gap: 10rpx; flex-shrink: 0; }
.distribution-order-card__amount-value { font-size: 28rpx; font-weight: 700; color: #ef4444; }
.distribution-order-card__status { padding: 8rpx 16rpx; border-radius: 9999rpx; font-size: 22rpx; }
.distribution-order-card__status--pending { color: #b45309; background: rgba(245, 158, 11, 0.14); }
.distribution-order-card__status--settled { color: #1a9d5c; background: rgba(26, 157, 92, 0.14); }
.distribution-order-card__status--refunded { color: #6b7280; background: rgba(107, 114, 128, 0.14); }
.distribution-rule-entry { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; }
.distribution-rule-entry__text { font-size: 28rpx; font-weight: 600; color: #1f2937; }
.distribution-rule-entry__arrow { font-size: 28rpx; color: #9ca3af; }
