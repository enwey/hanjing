.invite-page { background: #f2f3f5; padding-bottom: calc(132rpx + env(safe-area-inset-bottom)); }
.invite-banner { margin: 24rpx; padding: 32rpx 28rpx; border-radius: 36rpx; background: linear-gradient(135deg, #f5b743 0%, #f39b1a 100%); box-shadow: 0 16rpx 40rpx rgba(243, 155, 26, 0.22); }
.invite-banner__title { display: block; font-size: 38rpx; font-weight: 700; color: #ffffff; }
.invite-banner__desc { display: block; margin-top: 12rpx; font-size: 24rpx; line-height: 1.6; color: rgba(255, 255, 255, 0.92); }
.invite-banner__tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 24rpx; }
.invite-tag { padding: 8rpx 18rpx; border-radius: 9999rpx; background: rgba(255, 255, 255, 0.16); color: #ffffff; font-size: 20rpx; }
.invite-poster-section { background: transparent; box-shadow: none; padding: 0; }
.invite-section-title { margin: 0 24rpx; font-size: 30rpx; }
.invite-section-desc { margin: 8rpx 24rpx 0; font-size: 22rpx; color: #8c857b; }
.invite-notice { margin: 20rpx 24rpx 0; padding: 18rpx 20rpx; border-radius: 24rpx; background: #ffffff; color: #8c857b; font-size: 22rpx; line-height: 1.6; }
.invite-poster { margin: 20rpx 24rpx 0; padding: 32rpx 24rpx; border-radius: 36rpx; background: #3b6bf5; text-align: center; box-shadow: 0 18rpx 44rpx rgba(59, 107, 245, 0.2); }
.invite-poster__brand { display: block; font-size: 18rpx; letter-spacing: 3rpx; color: rgba(255, 255, 255, 0.76); }
.invite-poster__kicker { display: block; margin-top: 16rpx; font-size: 18rpx; letter-spacing: 3rpx; color: rgba(255, 255, 255, 0.92); }
.invite-poster__headline { display: block; margin-top: 18rpx; font-size: 48rpx; font-weight: 700; color: #ffffff; }
.invite-poster__subhead { display: block; margin-top: 12rpx; font-size: 28rpx; color: rgba(255, 255, 255, 0.88); }
.invite-poster__qr { width: 210rpx; height: 210rpx; margin: 28rpx auto 0; border-radius: 30rpx; background: #ffffff; display: flex; align-items: center; justify-content: center; }
.invite-poster__qr-image { width: 176rpx; height: 176rpx; }
.invite-poster__code-box { padding: 16rpx; }
.invite-poster__code-label { display: block; font-size: 18rpx; color: #8c857b; }
.invite-poster__code-value { display: block; margin-top: 10rpx; font-size: 26rpx; font-weight: 700; color: #3b6bf5; }
.invite-poster__footer { display: inline-flex; margin-top: 22rpx; padding: 10rpx 22rpx; border-radius: 9999rpx; background: rgba(255, 255, 255, 0.15); color: #ffffff; font-size: 20rpx; }
.invite-guide { margin-top: 8rpx; border-radius: 36rpx; }
.invite-guide__title { display: flex; align-items: center; font-size: 32rpx; font-weight: 700; }
.invite-guide__title::before { content: ''; width: 6rpx; height: 24rpx; margin-right: 12rpx; border-radius: 9999rpx; background: linear-gradient(180deg, #f5b743, #f39b1a); }
.invite-guide__flow { position: relative; margin-top: 26rpx; display: flex; flex-direction: column; gap: 26rpx; }
.invite-guide__line { position: absolute; left: 22rpx; top: 14rpx; bottom: 14rpx; border-left: 1rpx dashed #fde4b8; }
.invite-guide__step { position: relative; display: flex; align-items: flex-start; gap: 18rpx; }
.invite-guide__number { width: 52rpx; height: 52rpx; border-radius: 9999rpx; background: #fdf8f0; border: 3rpx solid #f39b1a; color: #f39b1a; display: flex; align-items: center; justify-content: center; font-size: 20rpx; font-weight: 700; }
.invite-guide__content { flex: 1; }
.invite-guide__step-title { display: block; font-size: 30rpx; font-weight: 600; color: #1c1a17; }
.invite-guide__step-desc { display: block; margin-top: 8rpx; font-size: 26rpx; line-height: 1.65; color: #8c857b; }
.invite-actions { position: fixed; left: 0; right: 0; bottom: 0; display: flex; gap: 16rpx; padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom)); background: rgba(251, 250, 247, 0.95); backdrop-filter: blur(12rpx); }
.invite-actions__button { height: 92rpx; border-radius: 9999rpx; display: flex; align-items: center; justify-content: center; gap: 10rpx; }
.invite-actions__button--secondary { flex: 1; background: #ffffff; border: 1rpx solid #e5e5e5; }
.invite-actions__button--primary { flex: 1.2; color: #ffffff; background: linear-gradient(135deg, #f5b743 0%, #f39b1a 100%); }
.invite-actions__icon { width: 30rpx; height: 30rpx; }
.invite-actions__icon--light { filter: brightness(0) invert(1); }
.invite-actions__text { font-size: 28rpx; font-weight: 600; }
.poster-canvas { position: fixed; left: -9999rpx; top: -9999rpx; width: 660rpx; height: 960rpx; pointer-events: none; opacity: 0; }
