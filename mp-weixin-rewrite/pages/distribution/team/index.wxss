.distribution-team-page { background: #f9fafb; padding-bottom: 40rpx; }
.state-card { text-align: center; }
.state-title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.stats-bar { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18rpx; }
.stats-item { padding: 24rpx 16rpx; border-radius: 20rpx; background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%); text-align: center; }
.stats-item__value { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.stats-item__label { display: block; margin-top: 10rpx; font-size: 22rpx; color: #6b7280; }
.member-list { display: flex; flex-direction: column; gap: 18rpx; }
.member-card { display: flex; align-items: center; gap: 20rpx; padding: 24rpx; border-radius: 24rpx; background: #ffffff; border: 1rpx solid #e5e7eb; }
.member-card__avatar { width: 84rpx; height: 84rpx; border-radius: 9999rpx; background: linear-gradient(135deg, #2456d7 0%, #5c96ff 100%); color: #ffffff; font-size: 28rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.member-card__body { flex: 1; min-width: 0; }
.member-card__name-row { display: flex; align-items: center; gap: 12rpx; }
.member-card__name { font-size: 28rpx; font-weight: 700; color: #1f2937; }
.member-card__status { padding: 6rpx 14rpx; border-radius: 9999rpx; font-size: 20rpx; }
.member-card__status--active { color: #1a9d5c; background: rgba(26, 157, 92, 0.14); }
.member-card__status--inactive { color: #6b7280; background: rgba(107, 114, 128, 0.14); }
.member-card__meta { display: block; margin-top: 10rpx; font-size: 24rpx; color: #6b7280; }
.member-card__aside { display: flex; flex-direction: column; align-items: flex-end; gap: 10rpx; flex-shrink: 0; }
.member-card__level { padding: 8rpx 16rpx; border-radius: 9999rpx; font-size: 22rpx; font-weight: 600; }
.member-card__level--gold { color: #b45309; background: rgba(245, 158, 11, 0.16); }
.member-card__level--silver { color: #475569; background: rgba(148, 163, 184, 0.18); }
.member-card__level--diamond { color: #2456d7; background: rgba(36, 86, 215, 0.14); }
.member-card__level--member { color: #6b7280; background: rgba(107, 114, 128, 0.14); }
.member-card__sales { font-size: 24rpx; color: #ef4444; font-weight: 700; }
