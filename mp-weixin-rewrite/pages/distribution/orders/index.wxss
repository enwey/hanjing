.distribution-orders-page { background: #f9fafb; padding-bottom: 40rpx; }
.distribution-order-tabs { display: flex; gap: 24rpx; padding: 16rpx 24rpx 0; overflow-x: auto; white-space: nowrap; }
.distribution-order-tab { position: relative; flex-shrink: 0; padding-bottom: 14rpx; }
.distribution-order-tab__text { font-size: 28rpx; font-weight: 600; color: #6b7280; }
.distribution-order-tab--active .distribution-order-tab__text { color: #3b6bf5; }
.distribution-order-tab--active::after { content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 6rpx; border-radius: 9999rpx; background: #3b6bf5; }
.summary-bar { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16rpx; }
.summary-item { padding: 22rpx 16rpx; border-radius: 20rpx; background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%); text-align: center; }
.summary-item__value { display: block; font-size: 26rpx; font-weight: 700; color: #1f2937; }
.summary-item__label { display: block; margin-top: 10rpx; font-size: 22rpx; color: #6b7280; }
.state-card { text-align: center; }
.state-title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.distribution-order-list { display: flex; flex-direction: column; gap: 20rpx; }
.distribution-order-item { display: flex; gap: 20rpx; align-items: flex-start; }
.distribution-order-item__cover { width: 120rpx; height: 120rpx; border-radius: 20rpx; overflow: hidden; background: #eef2f7; flex-shrink: 0; }
.distribution-order-item__cover-image { width: 100%; height: 100%; }
.distribution-order-item__placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #e5e7eb 0%, #f3f4f6 100%); }
.distribution-order-item__body { flex: 1; min-width: 0; }
.distribution-order-item__title { display: block; font-size: 28rpx; font-weight: 700; color: #1f2937; }
.distribution-order-item__meta { display: block; margin-top: 8rpx; font-size: 24rpx; color: #6b7280; }
.distribution-order-item__commission { display: block; margin-top: 10rpx; font-size: 26rpx; font-weight: 700; color: #ef4444; }
.distribution-order-item__status { padding: 8rpx 16rpx; border-radius: 9999rpx; font-size: 22rpx; flex-shrink: 0; }
.distribution-order-item__status--pending { color: #b45309; background: rgba(245, 158, 11, 0.14); }
.distribution-order-item__status--settled { color: #1a9d5c; background: rgba(26, 157, 92, 0.14); }
.distribution-order-item__status--refunded { color: #6b7280; background: rgba(107, 114, 128, 0.14); }
