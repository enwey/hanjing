.live-list-page { background: #f5f6f8; padding-bottom: 40rpx; }
.live-tabs { display: flex; gap: 12rpx; padding: 20rpx 24rpx 0; overflow-x: auto; white-space: nowrap; }
.live-tab { flex-shrink: 0; padding: 14rpx 28rpx; border-radius: 16rpx; background: #ffffff; font-size: 26rpx; color: #6b7280; }
.live-tab--active { background: #eef4ff; color: #3b6bf5; font-weight: 700; }
.state-card { text-align: center; }
.state-title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.live-card + .live-card { margin-top: 20rpx; }
.live-card { border-radius: 24rpx; overflow: hidden; background: #ffffff; }
.live-card__cover-wrap { position: relative; height: 360rpx; background: #f3f4f6; }
.live-card__cover { width: 100%; height: 100%; }
.live-card__cover--empty { background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%); }
.live-card__status { position: absolute; top: 18rpx; left: 18rpx; padding: 8rpx 18rpx; border-radius: 9999rpx; font-size: 22rpx; color: #ffffff; }
.live-card__status--live { background: #ef4444; }
.live-card__status--replay { background: #3b6bf5; }
.live-card__status--upcoming { background: #f59e0b; }
.live-card__time { position: absolute; right: 18rpx; bottom: 18rpx; padding: 8rpx 14rpx; border-radius: 12rpx; background: rgba(0, 0, 0, 0.48); color: #ffffff; font-size: 22rpx; }
.live-card__body { padding: 22rpx 24rpx 24rpx; }
.live-card__title { display: block; font-size: 30rpx; line-height: 1.5; font-weight: 700; color: #1f2937; }
.live-card__meta { display: flex; align-items: center; flex-wrap: wrap; gap: 12rpx; margin-top: 16rpx; }
.live-card__anchor { display: flex; align-items: center; }
.live-card__anchor-avatar { width: 40rpx; height: 40rpx; margin-right: 8rpx; border-radius: 9999rpx; background: #eef4ff; color: #3b6bf5; font-size: 20rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.live-card__anchor-name, .live-card__viewer { font-size: 24rpx; color: #6b7280; }
.live-card__tags { display: flex; gap: 8rpx; flex-wrap: wrap; margin-top: 14rpx; }
.live-card__tag { padding: 4rpx 12rpx; border-radius: 9999rpx; background: #f3f4f6; font-size: 20rpx; color: #6b7280; }
.live-card__action-row { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; margin-top: 18rpx; }
.live-card__room-id { flex: 1; font-size: 22rpx; color: #6b7280; }
.live-card__action { flex-shrink: 0; padding: 10rpx 22rpx; border-radius: 9999rpx; background: linear-gradient(135deg, #2456d7 0%, #5c96ff 100%); color: #ffffff; font-size: 22rpx; font-weight: 700; }
