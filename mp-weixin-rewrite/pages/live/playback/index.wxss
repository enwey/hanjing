.live-detail-page { min-height: 100vh; background: #0f172a; padding-bottom: 40rpx; }
.state-card { text-align: center; color: #ffffff; }
.state-title { display: block; font-size: 30rpx; font-weight: 700; }
.live-hero { position: relative; height: 440rpx; }
.live-hero__cover { width: 100%; height: 100%; }
.live-hero__cover--empty { background: linear-gradient(160deg, #1a3580 0%, #3b6bf5 40%, #8eafff 100%); }
.live-hero__mask { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(15, 23, 42, 0.16), rgba(15, 23, 42, 0.88)); }
.live-hero__content { position: absolute; left: 24rpx; right: 24rpx; bottom: 28rpx; }
.live-hero__status { display: inline-flex; align-items: center; padding: 8rpx 20rpx; border-radius: 9999rpx; font-size: 22rpx; color: #ffffff; }
.live-hero__status--live { background: #ef4444; }
.live-hero__status--replay { background: #3b6bf5; }
.live-hero__status--upcoming { background: #f59e0b; }
.live-hero__title { display: block; margin-top: 18rpx; font-size: 38rpx; line-height: 1.45; font-weight: 700; color: #ffffff; }
.live-hero__sub { display: block; margin-top: 10rpx; font-size: 24rpx; color: rgba(255, 255, 255, 0.76); }
.live-info { background: #111827; }
.live-info__meta { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.live-info__anchor { display: flex; align-items: center; }
.live-info__anchor-avatar { width: 44rpx; height: 44rpx; margin-right: 10rpx; border-radius: 9999rpx; background: #eef4ff; color: #3b6bf5; font-size: 22rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.live-info__anchor-name { font-size: 24rpx; color: rgba(255, 255, 255, 0.72); }
.live-info__time, .live-info__viewer { font-size: 22rpx; color: rgba(255, 255, 255, 0.46); }
.live-info__viewer { display: block; margin-top: 12rpx; }
.live-info__desc { display: block; margin-top: 16rpx; font-size: 24rpx; line-height: 1.7; color: rgba(255, 255, 255, 0.64); }
.live-info__button { margin-top: 22rpx; height: 84rpx; line-height: 84rpx; border-radius: 9999rpx; border: none; background: linear-gradient(135deg, #2456d7 0%, #5c96ff 100%); color: #ffffff; font-size: 28rpx; font-weight: 700; }
.live-info__button::after { border: none; }
.section-title { display: block; margin-bottom: 20rpx; font-size: 30rpx; font-weight: 700; color: #ffffff; }
.product-scroll { white-space: nowrap; }
.product-scroll__list { display: flex; gap: 16rpx; }
.live-product-card { width: 220rpx; flex-shrink: 0; overflow: hidden; border-radius: 18rpx; background: rgba(255, 255, 255, 0.06); }
.live-product-card__image { width: 220rpx; height: 140rpx; }
.live-product-card__image--empty { background: rgba(255, 255, 255, 0.12); }
.live-product-card__body { padding: 14rpx; }
.live-product-card__name { display: block; font-size: 24rpx; color: rgba(255, 255, 255, 0.82); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.live-product-card__price { display: block; margin-top: 8rpx; font-size: 28rpx; font-weight: 700; color: #f2c14e; }
