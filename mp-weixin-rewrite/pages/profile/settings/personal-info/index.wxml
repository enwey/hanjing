<view class="container personal-info-page">
  <hj-navbar title="个人信息" showBack="{{true}}" />
  <view class="page-section state-card" wx:if="{{loading}}">
    <text class="page-description">加载中...</text>
  </view>
  <block wx:elif="{{profile}}">
    <view class="page-section">
      <view class="avatar-badge">{{summary.avatarBadge}}</view>
      <view class="summary-grid">
        <view class="summary-item">
          <text class="summary-item__value">{{summary.nickname || '未设置'}}</text>
          <text class="summary-item__label">昵称</text>
        </view>
        <view class="summary-item">
          <text class="summary-item__value">{{summary.genderLabel || '未设置'}}</text>
          <text class="summary-item__label">性别</text>
        </view>
        <view class="summary-item">
          <text class="summary-item__value">{{summary.birthday || '未设置'}}</text>
          <text class="summary-item__label">生日</text>
        </view>
        <view class="summary-item">
          <text class="summary-item__value">{{summary.cardNo || '未生成'}}</text>
          <text class="summary-item__label">就诊卡号</text>
        </view>
      </view>
      <view class="form-list">
        <view class="form-row">
          <text class="form-label">昵称</text>
          <input wx:if="{{editing}}" class="form-input" value="{{form.nickname}}" bindinput="onInputNickname" />
          <text wx:else class="form-value">{{profile.nickname}}</text>
        </view>
        <view class="form-row">
          <text class="form-label">手机号</text>
          <text class="form-value form-value--muted">{{profile.phone}}</text>
        </view>
        <view class="form-row">
          <text class="form-label">身份证号</text>
          <input wx:if="{{editing}}" class="form-input" maxlength="18" value="{{form.idCard}}" bindinput="onInputIdCard" />
          <text wx:else class="form-value form-value--muted">{{summary.idCardMasked || '未认证'}}</text>
        </view>
        <view class="form-row">
          <text class="form-label">病历号（就诊卡号）</text>
          <text class="form-value form-value--muted">{{profile.cardNo || '未生成'}}</text>
        </view>
        <view class="form-row">
          <text class="form-label">性别</text>
          <view wx:if="{{editing}}" class="chip-row">
            <view class="chip {{form.gender === 1 ? 'chip--active' : ''}}" data-gender="1" bindtap="chooseGender">男</view>
            <view class="chip {{form.gender === 2 ? 'chip--active' : ''}}" data-gender="2" bindtap="chooseGender">女</view>
          </view>
          <text wx:else class="form-value">{{summary.genderLabel || '未设置'}}</text>
        </view>
        <view class="form-row">
          <text class="form-label">生日</text>
          <picker wx:if="{{editing}}" mode="date" value="{{form.birthday}}" bindchange="chooseBirthday">
            <view class="form-input">{{form.birthday || '请选择生日'}}</view>
          </picker>
          <text wx:else class="form-value">{{profile.birthday || '未设置'}}</text>
        </view>
      </view>
    </view>
    <view class="page-section personal-info-page__actions">
      <view wx:if="{{!editing}}" class="primary-button" bindtap="startEdit">编辑资料</view>
      <block wx:else>
        <view class="primary-button" bindtap="saveProfile">保存</view>
        <view class="ghost-button" bindtap="cancelEdit">取消</view>
      </block>
    </view>
  </block>
</view>
