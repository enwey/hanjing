.settings-page { min-height: 100vh; padding-bottom: 40rpx; background: linear-gradient(180deg, #eef4ff 0, #f7f8fb 220rpx, #f7f8fb 100%); }
.settings-hero { margin: 24rpx; padding: 32rpx 28rpx; border-radius: 30rpx; background: linear-gradient(135deg, #ffffff 0%, #eef4ff 100%); box-shadow: 0 14rpx 32rpx rgba(36, 87, 230, 0.1); }
.settings-hero__title { display: block; font-size: 38rpx; font-weight: 700; color: #111827; }
.settings-hero__desc { display: block; margin-top: 12rpx; font-size: 24rpx; line-height: 1.6; color: #6b7280; }
.section-title { display: block; margin-bottom: 20rpx; font-size: 30rpx; font-weight: 700; color: #111827; }
.menu-list { display: flex; flex-direction: column; gap: 16rpx; }
.menu-item { display: flex; align-items: center; gap: 18rpx; padding: 18rpx 4rpx; }
.menu-item__icon-wrap { width: 72rpx; height: 72rpx; border-radius: 22rpx; background: linear-gradient(135deg, #eef4ff 0%, #f8fbff 100%); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.menu-item__icon { width: 36rpx; height: 36rpx; }
.menu-item__body { flex: 1; min-width: 0; }
.menu-item__title { display: block; font-size: 28rpx; font-weight: 700; color: #111827; }
.menu-item__desc { display: block; margin-top: 8rpx; font-size: 23rpx; line-height: 1.6; color: #6b7280; }
.menu-item__arrow { width: 24rpx; height: 24rpx; flex-shrink: 0; }
.settings-page__action-bar { background: transparent; box-shadow: none; }
.logout-button { height: 84rpx; line-height: 84rpx; border-radius: 999rpx; background: #fef2f2; color: #ef4444; font-size: 28rpx; font-weight: 700; }
.logout-button::after { border: 0; }
