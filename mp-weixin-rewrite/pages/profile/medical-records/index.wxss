.medical-record-page { background: #f9fafb; padding-bottom: 40rpx; }
.section-title { display: block; margin-bottom: 20rpx; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.patient-switcher { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; padding: 24rpx; border-radius: 20rpx; background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%); border: 1rpx solid #d9e6ff; }
.patient-switcher__body { flex: 1; min-width: 0; }
.patient-switcher__label { display: block; font-size: 28rpx; font-weight: 600; color: #1f2937; }
.patient-switcher__meta { display: block; margin-top: 8rpx; font-size: 22rpx; color: #6b7280; }
.patient-switcher__action { font-size: 24rpx; color: #3b6bf5; }
.summary-bar { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16rpx; }
.summary-item { padding: 22rpx 16rpx; border-radius: 20rpx; background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%); text-align: center; }
.summary-item__value { display: block; font-size: 26rpx; font-weight: 700; color: #1f2937; }
.summary-item__label { display: block; margin-top: 10rpx; font-size: 22rpx; color: #6b7280; }
.state-card { text-align: center; }
.state-title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.record-list { display: flex; flex-direction: column; gap: 20rpx; }
.record-card { padding: 28rpx; background: #ffffff; border: 1rpx solid #e5e7eb; border-radius: 24rpx; }
.record-card__header { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.record-card__title { flex: 1; font-size: 28rpx; font-weight: 700; color: #1f2937; }
.record-card__type { padding: 8rpx 18rpx; border-radius: 9999rpx; font-size: 22rpx; font-weight: 600; }
.record-card__meta, .record-card__content { display: block; margin-top: 12rpx; font-size: 24rpx; line-height: 1.65; color: #4b5563; }
