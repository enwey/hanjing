<view class="container online-service-page">
  <hj-navbar title="在线客服" showBack="{{true}}" />

  <scroll-view class="chat-area" scroll-y="true" scroll-into-view="{{scrollIntoView}}" enhanced="true" show-scrollbar="false">
    <view class="chat-list">
      <view wx:for="{{messages}}" wx:key="id" id="message-{{item.id}}" class="chat-message chat-message--{{item.from}}">
        <view class="chat-bubble chat-bubble--{{item.bubbleClass}}">
          <image wx:if="{{item.isImage}}" src="{{item.displayUrl}}" mode="widthFix" class="chat-bubble__image" bindtap="onPreviewImage" data-src="{{item.displayUrl}}" />
          <text wx:else class="chat-bubble__text">{{item.text}}</text>
          <text wx:if="{{item.sending}}" class="chat-bubble__sending">发送中...</text>
          <text wx:if="{{item.failed}}" class="chat-bubble__failed" bindtap="retrySendMessage" data-id="{{item.id}}">发送失败，点击重试</text>
          <text class="chat-bubble__time">{{item.time}}</text>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="chat-input-bar">
    <view class="chat-input-bar__icon" bindtap="onUploadImage">
      <image src="/static/icons/image-plus.svg" mode="aspectFit" class="chat-input-bar__icon-image" />
    </view>
    <input class="chat-input-bar__input" placeholder="输入您的问题..." confirm-type="send" bindconfirm="sendMessage" value="{{draftMessage}}" bindinput="handleDraftInput" />
    <view class="chat-input-bar__button" bindtap="sendMessage">发送</view>
  </view>
</view>
