.family-page { background: #f9fafb; padding-bottom: 40rpx; }
.family-page__hero { background: linear-gradient(135deg, #ffffff 0%, #eef4ff 100%); }
.family-page__patient-name { display: block; margin-top: 10rpx; font-size: 42rpx; font-weight: 700; color: #1f2937; }
.family-summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 16rpx; }
.family-summary__item { padding: 22rpx 16rpx; border-radius: 20rpx; background: #ffffff; text-align: center; box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.04); }
.family-summary__value { display: block; font-size: 28rpx; font-weight: 700; color: #1f2937; }
.family-summary__label { display: block; margin-top: 8rpx; font-size: 22rpx; color: #6b7280; }
.state-card { text-align: center; }
.state-title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.section-title { display: block; margin-bottom: 20rpx; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.member-list { display: flex; flex-direction: column; gap: 20rpx; }
.member-card { display: flex; gap: 24rpx; padding: 28rpx; border: 1rpx solid #e5e7eb; border-radius: 24rpx; background: #ffffff; }
.member-card--active { border-color: #3b6bf5; background: linear-gradient(135deg, rgba(59, 107, 245, 0.06) 0%, #ffffff 100%); }
.member-card__avatar { width: 96rpx; height: 96rpx; border-radius: 28rpx; background: #dbeafe; color: #3b6bf5; display: flex; align-items: center; justify-content: center; font-size: 34rpx; font-weight: 700; flex-shrink: 0; }
.member-card__body { flex: 1; min-width: 0; }
.member-card__header { display: flex; align-items: center; gap: 14rpx; flex-wrap: wrap; }
.member-card__name { font-size: 30rpx; font-weight: 700; color: #1f2937; }
.member-card__relation { padding: 6rpx 16rpx; border-radius: 9999rpx; background: rgba(59, 107, 245, 0.12); font-size: 22rpx; color: #3b6bf5; }
.member-card__current-tag { padding: 6rpx 16rpx; border-radius: 9999rpx; background: rgba(16, 185, 129, 0.12); font-size: 22rpx; color: #059669; }
.member-card__meta { display: block; margin-top: 10rpx; font-size: 24rpx; line-height: 1.6; color: #6b7280; word-break: break-all; }
.family-page__action-bar { padding: 12rpx 24rpx; background: transparent; box-shadow: none; }
