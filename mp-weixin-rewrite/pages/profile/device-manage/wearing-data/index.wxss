.wearing-page { background: #f9fafb; padding-bottom: 40rpx; }
.summary-card { background: linear-gradient(135deg, #2456d7 0%, #5c96ff 100%); color: #ffffff; }
.summary-card__title { display: block; font-size: 30rpx; font-weight: 700; }
.summary-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16rpx; margin-top: 24rpx; }
.summary-item { text-align: center; }
.summary-item__value { display: block; font-size: 32rpx; font-weight: 700; }
.summary-item__label { display: block; margin-top: 10rpx; font-size: 22rpx; opacity: 0.88; }
.state-card { text-align: center; }
.state-title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.record-list { display: flex; flex-direction: column; gap: 18rpx; }
.record-card { padding: 24rpx; border-radius: 24rpx; background: #ffffff; border: 1rpx solid #e5e7eb; }
.record-card__header { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.record-card__date { font-size: 28rpx; font-weight: 700; color: #1f2937; }
.record-card__status { padding: 8rpx 18rpx; border-radius: 9999rpx; font-size: 22rpx; font-weight: 600; }
.record-card__hours { display: block; margin-top: 16rpx; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.record-card__progress { margin-top: 18rpx; height: 14rpx; border-radius: 9999rpx; background: #eef2f7; overflow: hidden; }
.record-card__progress-bar { height: 100%; border-radius: 9999rpx; }
