.feedback-page { background: #f9fafb; padding-bottom: 40rpx; }
.page-intro__title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.page-intro__desc { display: block; margin-top: 12rpx; font-size: 24rpx; line-height: 1.6; color: #6b7280; }
.action-row { padding-top: 0; }
.primary-action { display: flex; align-items: center; justify-content: center; gap: 14rpx; padding: 24rpx; border-radius: 24rpx; background: linear-gradient(135deg, #2456d7 0%, #5c96ff 100%); color: #ffffff; }
.primary-action__icon { width: 34rpx; height: 34rpx; }
.primary-action__text { font-size: 28rpx; font-weight: 700; }
.state-card { text-align: center; }
.state-title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.record-list { display: flex; flex-direction: column; gap: 18rpx; }
.record-card { padding: 24rpx; border-radius: 24rpx; background: #ffffff; border: 1rpx solid #e5e7eb; }
.record-card__header { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.record-card__stars { font-size: 24rpx; color: #f59e0b; letter-spacing: 4rpx; }
.record-card__date { font-size: 22rpx; color: #9ca3af; }
.record-card__content { display: block; margin-top: 14rpx; font-size: 26rpx; line-height: 1.7; color: #1f2937; }
.record-card__status { display: inline-block; margin-top: 16rpx; padding: 8rpx 18rpx; border-radius: 9999rpx; font-size: 22rpx; color: #3b6bf5; background: rgba(59, 107, 245, 0.12); }
.modal-mask { position: fixed; inset: 0; background: rgba(17, 24, 39, 0.48); display: flex; align-items: flex-end; z-index: 20; }
.modal-card { width: 100%; padding: 32rpx 28rpx 40rpx; border-radius: 32rpx 32rpx 0 0; background: #ffffff; }
.modal-card__title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.rating-row { display: flex; gap: 18rpx; margin-top: 26rpx; }
.rating-star { font-size: 42rpx; color: #d1d5db; }
.rating-star--active { color: #f59e0b; }
.composer-textarea { width: 100%; height: 220rpx; margin-top: 24rpx; padding: 24rpx; border-radius: 24rpx; background: #f9fafb; font-size: 26rpx; line-height: 1.7; box-sizing: border-box; }
.modal-actions { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18rpx; margin-top: 28rpx; }
.modal-button { display: flex; align-items: center; justify-content: center; min-height: 88rpx; border-radius: 9999rpx; font-size: 28rpx; font-weight: 700; }
.modal-button--ghost { color: #1f2937; background: #f3f4f6; }
.modal-button--primary { color: #ffffff; background: linear-gradient(135deg, #2456d7 0%, #5c96ff 100%); }
