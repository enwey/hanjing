<view class="container feedback-page">
  <hj-navbar title="使用反馈" showBack="{{true}}" />

  <view class="page-section page-intro">
    <text class="page-intro__title">{{selectedMemberLabel}}</text>
    <text class="page-intro__desc">记录当前设备使用感受、问题反馈和处理进度。</text>
  </view>

  <view class="page-section action-row">
    <view class="primary-action" bindtap="openComposer">
      <image src="/static/icons/compose.svg" mode="aspectFit" class="primary-action__icon" />
      <text class="primary-action__text">提交反馈</text>
    </view>
  </view>

  <view class="page-section state-card" wx:if="{{loading}}">
    <text class="page-description">正在加载反馈记录...</text>
  </view>

  <view class="page-section state-card" wx:elif="{{loadError}}">
    <text class="state-title">加载失败</text>
    <text class="page-description">{{loadError}}</text>
  </view>

  <view class="page-section state-card" wx:elif="{{!records.length}}">
    <text class="state-title">暂无使用反馈</text>
    <text class="page-description">当前设备还没有提交过反馈，遇到问题可以直接在这里反馈。</text>
  </view>

  <view class="page-section" wx:else>
    <view class="record-list">
      <view wx:for="{{records}}" wx:key="id" class="record-card">
        <view class="record-card__header">
          <text class="record-card__stars">{{item.ratingStars || '未评分'}}</text>
          <text class="record-card__date">{{item.dateLabel}}</text>
        </view>
        <text class="record-card__content">{{item.content}}</text>
        <text class="record-card__status" wx:if="{{item.statusLabel}}">{{item.statusLabel}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{showComposer}}" class="modal-mask" bindtap="closeComposer">
    <view class="modal-card" catchtap="noop">
      <text class="modal-card__title">提交使用反馈</text>
      <view class="rating-row">
        <text
          wx:for="{{ratingOptions}}"
          wx:key="*this"
          class="rating-star {{rating >= item ? 'rating-star--active' : ''}}"
          data-value="{{item}}"
          bindtap="chooseRating"
        >
          ★
        </text>
      </view>
      <textarea class="composer-textarea" maxlength="300" placeholder="请填写佩戴体验、问题现象或希望改进的点" value="{{content}}" bindinput="handleContentInput" />
      <view class="modal-actions">
        <view class="modal-button modal-button--ghost" bindtap="closeComposer">取消</view>
        <view class="modal-button modal-button--primary" bindtap="submitFeedback">{{submitting ? '提交中' : '确认提交'}}</view>
      </view>
    </view>
  </view>
</view>
