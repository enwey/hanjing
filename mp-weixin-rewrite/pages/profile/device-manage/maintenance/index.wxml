<view class="container maintenance-page">
  <hj-navbar title="维护记录" showBack="{{true}}" />

  <view class="page-section page-intro">
    <text class="page-intro__title">{{selectedMemberLabel}}</text>
    <text class="page-intro__desc">只展示当前绑定设备对应的维护、调整与更换记录。</text>
  </view>

  <view class="page-section state-card" wx:if="{{loading}}">
    <text class="page-description">正在加载维护记录...</text>
  </view>

  <view class="page-section state-card" wx:elif="{{loadError}}">
    <text class="state-title">加载失败</text>
    <text class="page-description">{{loadError}}</text>
  </view>

  <view class="page-section state-card" wx:elif="{{!records.length}}">
    <text class="state-title">暂无维护记录</text>
    <text class="page-description">当前设备暂时没有维护、维修或更换记录。</text>
  </view>

  <block wx:else>
    <view class="page-section summary-bar">
      <view class="summary-item">
        <text class="summary-item__value">{{summary.totalCount}}</text>
        <text class="summary-item__label">记录总数</text>
      </view>
      <view class="summary-item" wx:if="{{summary.totalCostLabel}}">
        <text class="summary-item__value">{{summary.totalCostLabel}}</text>
        <text class="summary-item__label">累计费用</text>
      </view>
      <view class="summary-item" wx:if="{{summary.latestDateLabel}}">
        <text class="summary-item__value">{{summary.latestDateLabel}}</text>
        <text class="summary-item__label">最近记录</text>
      </view>
    </view>

    <view class="page-section">
    <view class="record-list">
      <view wx:for="{{records}}" wx:key="id" class="record-card">
        <view class="record-card__header">
          <text class="record-card__title">{{item.title}}</text>
          <text class="record-card__type" style="color: {{item.typeColor}}; background: {{item.typeColor}}18;">{{item.typeLabel}}</text>
        </view>
        <text class="record-card__meta" wx:if="{{item.dateLabel}}">时间：{{item.dateLabel}}</text>
        <text class="record-card__meta" wx:if="{{item.operatorName}}">处理人：{{item.operatorName}}</text>
        <text class="record-card__meta" wx:if="{{item.costLabel}}">费用：{{item.costLabel}}</text>
        <text class="record-card__desc" wx:if="{{item.description}}">{{item.description}}</text>
      </view>
    </view>
    </view>
  </block>
</view>
