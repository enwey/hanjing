.order-page {
  min-height: 100vh;
  background: #f9fafb;
  display: flex;
  flex-direction: column;
}

.page-content {
  flex: 1;
  padding: 0 24rpx;
}

.order-tabs {
  position: sticky;
  z-index: 99;
  display: flex;
  height: 96rpx;
  margin: 0 -24rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: #ffffff;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.08);
  white-space: nowrap;
}

.order-tab {
  position: relative;
  flex: 1;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
}

.order-tab__text {
  font-size: 30rpx;
  line-height: 1;
  font-weight: 500;
  color: rgba(0, 0, 0, 0.55);
}

.order-tab--active .order-tab__text {
  color: #3b6bf5;
  font-weight: 600;
}

.order-tab--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  width: 56rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #3b6bf5;
  transform: translateX(-50%);
}

.state-card {
  padding: 160rpx 0;
  text-align: center;
}

.state-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.order-list {
  padding: 0 8rpx;
  margin-top: 24rpx;
}

.order-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
}

.order-card__header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.order-card__number {
  font-size: 26rpx;
  color: #9ca3af;
}

.order-card__status {
  font-size: 26rpx;
  font-weight: 600;
}

.order-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.order-item__cover-image,
.order-item__placeholder {
  width: 128rpx;
  height: 128rpx;
  border-radius: 16rpx;
  background: #f3f4f6;
  flex-shrink: 0;
}

.order-item__placeholder {
  background: #eef4ff;
}

.order-item__body {
  flex: 1;
  min-width: 0;
}

.order-item__name {
  display: block;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.order-item__count {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #9ca3af;
}

.order-item__price {
  flex-shrink: 0;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.order-card__footer {
  display: flex;
  justify-content: flex-end;
  align-items: baseline;
  gap: 8rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f3f4f6;
}

.order-card__count {
  font-size: 26rpx;
  color: #6b7280;
}

.order-card__amount {
  font-size: 34rpx;
  font-weight: 700;
  color: #ef4444;
}

.safe-bottom {
  height: calc(env(safe-area-inset-bottom, 34px) + 40rpx);
}
