<view class="page order-page">
  <hj-navbar title="我的订单" showBack="{{true}}" />

  <view class="page-content">
    <view class="order-tabs" style="top: {{navbarHeight}}px;">
      <view
        wx:for="{{orderTabs}}"
        wx:key="key"
        class="order-tab {{selectedStatus === item.key ? 'order-tab--active' : ''}}"
        data-status-key="{{item.key}}"
        bindtap="handleTabTap"
      >
        <text class="order-tab__text">{{item.label}}</text>
      </view>
    </view>

    <view class="state-card" wx:if="{{loading}}">
      <text class="state-text">加载中...</text>
    </view>

    <view wx:elif="{{visibleOrders.length}}" class="order-list">
      <view wx:for="{{visibleOrders}}" wx:key="id" class="order-card" data-order-id="{{item.id}}" bindtap="openDetail">
        <view class="order-card__header">
          <text class="order-card__number">{{item.orderNo}}</text>
          <text class="order-card__status" style="color: {{item.statusColor}};">{{item.statusLabel}}</text>
        </view>

        <view wx:for="{{item.items}}" wx:key="productId" class="order-item">
          <image wx:if="{{item.productImage}}" src="{{item.productImage}}" mode="aspectFill" class="order-item__cover-image" />
          <view wx:else class="order-item__placeholder"></view>
          <view class="order-item__body">
            <text class="order-item__name">{{item.productName}}</text>
            <text class="order-item__count">x{{item.quantity}}</text>
          </view>
          <text class="order-item__price">{{item.priceLabel}}</text>
        </view>

        <view class="order-card__footer">
          <text class="order-card__count">{{item.itemCountLabel}}，合计</text>
          <text class="order-card__amount">{{item.payAmountLabel}}</text>
        </view>
      </view>
    </view>

    <view wx:else class="state-card">
      <text class="state-text">暂无订单</text>
    </view>

    <view class="safe-bottom"></view>
  </view>
</view>
