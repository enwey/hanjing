.page {
  min-height: 100vh;
  background: #f9fafb;
}

.page-content {
  padding: 32rpx 32rpx 200rpx;
}

.info-card {
  margin-bottom: 24rpx;
  padding: 40rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.info-title {
  display: block;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2937;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.row-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.info-label {
  width: 112rpx;
  flex-shrink: 0;
  font-size: 28rpx;
  color: #6b7280;
}

.info-value {
  flex: 1;
  font-size: 30rpx;
  color: #1f2937;
}

.info-value--bold {
  font-weight: 600;
  color: #3b6bf5;
}

.info-value--price {
  font-weight: 600;
  color: #ef4444;
}

.symptom-card {
  margin-bottom: 24rpx;
  padding: 40rpx;
  border-radius: 32rpx;
  background: #ffffff;
}

.symptom-title {
  display: block;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.symptom-textarea {
  width: 100%;
  height: 240rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 24rpx;
  background: #f9fafb;
  font-size: 28rpx;
  color: #374151;
}

.visit-notice-card {
  margin-bottom: 40rpx;
  padding: 32rpx;
  border: 1rpx solid #fde6b8;
  border-radius: 24rpx;
  background: #fffaf0;
}

.visit-notice-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.visit-notice-header-icon {
  width: 36rpx;
  margin-right: 12rpx;
  color: #f59e0b;
  font-size: 30rpx;
  line-height: 1;
}

.visit-notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #d97706;
}

.visit-notice-item {
  display: flex;
  align-items: flex-start;
  padding: 8rpx 0;
}

.visit-notice-index {
  width: 32rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  line-height: 1.5;
  color: #4b5563;
}

.visit-notice-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.5;
  color: #4b5563;
}

.state-card {
  padding: 48rpx 32rpx;
  text-align: center;
}

.state-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.state-description {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.bottom-fixed-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  height: 140rpx;
  padding: 0 40rpx env(safe-area-inset-bottom, 0);
  background: #ffffff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
  box-sizing: content-box;
}

.bar-primary-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #3b6bf5 0%, #5a85f5 50%, #8eafff 100%);
  box-shadow: 0 8rpx 28rpx rgba(59, 107, 245, 0.25);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.bar-primary-btn::after {
  border: none;
}

.safe-bottom {
  height: calc(env(safe-area-inset-bottom, 34px) + 40rpx);
}
