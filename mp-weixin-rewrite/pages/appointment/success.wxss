.page {
  min-height: 100vh;
  background: #f9fafb;
}

.page-content {
  padding: 0 48rpx 80rpx;
}

.state-card {
  padding-top: 160rpx;
  text-align: center;
}

.state-text {
  display: block;
  font-size: 28rpx;
  line-height: 1.6;
  color: #6b7280;
}

.success-icon {
  display: flex;
  justify-content: center;
  padding: 80rpx 0 40rpx;
}

.success-medical-icon {
  width: 160rpx;
  height: 160rpx;
  transform: translateX(-8rpx);
}

.success-title {
  display: block;
  margin-bottom: 16rpx;
  text-align: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #1f2937;
}

.success-desc {
  display: block;
  margin-bottom: 64rpx;
  text-align: center;
  font-size: 28rpx;
  color: #6b7280;
}

.summary-card {
  margin-bottom: 48rpx;
  padding: 40rpx;
  border-radius: 32rpx;
  background: #ffffff;
}

.summary-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
}

.summary-row:not(:last-child) {
  border-bottom: 1rpx solid #f3f4f6;
}

.summary-label {
  width: 144rpx;
  font-size: 28rpx;
  color: #9ca3af;
}

.summary-value {
  flex: 1;
  font-size: 30rpx;
  color: #1f2937;
}

.summary-value--no {
  color: #3b6bf5;
  font-family: SFMono-Regular, Consolas, monospace;
}

.summary-value--bold {
  font-weight: 600;
  color: #3b6bf5;
}

.summary-value--price {
  color: #ef4444;
  font-weight: 600;
}

.visit-notice-card {
  margin-bottom: 40rpx;
  padding: 32rpx;
  border: 1rpx solid #fde6b8;
  border-radius: 24rpx;
  background: #fffaf0;
}

.visit-notice-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.visit-notice-header-icon {
  margin-right: 12rpx;
  font-size: 30rpx;
  line-height: 1;
  color: #f59e0b;
}

.visit-notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #d97706;
}

.visit-notice-item {
  display: flex;
  align-items: flex-start;
  padding: 8rpx 0;
}

.visit-notice-index {
  width: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  line-height: 1.5;
  color: #4b5563;
}

.visit-notice-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.5;
  color: #4b5563;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.remind {
  text-align: center;
}

.remind-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.remind-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.remind-text {
  font-size: 26rpx;
  color: #9ca3af;
}
