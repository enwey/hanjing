<view class="page">
  <hj-navbar title="改约" showBack="{{true}}" />

  <view class="page-content">
    <view class="state-card" wx:if="{{loading && !scheduleDates.length}}">
      <text class="state-text">正在加载可改约时段...</text>
    </view>

    <view class="state-card" wx:elif="{{loadError}}">
      <text class="state-text">{{loadError}}</text>
    </view>

    <block wx:else>
      <hj-schedule-calendar
        dates="{{scheduleDates}}"
        selectedDate="{{selectedDate}}"
        bind:select="selectDate"
      />

      <view wx:if="{{selectedDate && schedules.length > 0}}">
        <block wx:for="{{schedules}}" wx:key="id">
          <view
            class="schedule-header"
            data-schedule-id="{{item.id}}"
            bindtap="tapSchedule"
          >
            <text class="schedule-period">{{item.periodLabel}}</text>
            <text class="schedule-time">{{item.startTime}}-{{item.endTime}}</text>
          </view>

          <view wx:if="{{selectedScheduleId === item.id}}" class="slot-grid">
            <view
              wx:for="{{timeSlots}}"
              wx:key="id"
              class="slot {{item.selectable ? 'slot--available' : ''}} {{selectedTimeSlotId === item.id ? 'slot--selected' : ''}} {{item.status === 'booked' ? 'slot--booked' : ''}}"
              data-time-slot-id="{{item.id}}"
              bindtap="selectTimeSlot"
            >
              <text>{{item.label}}</text>
            </view>
          </view>
        </block>
      </view>

      <view wx:elif="{{selectedDate && !loading}}" class="empty-card">
        <text class="empty-text">该日期暂无可改约时段</text>
      </view>

      <view class="submit-area">
        <hj-button
          text="{{submitting ? '提交中...' : '确认改约'}}"
          bind:tap="submitReschedule"
        />
      </view>
    </block>
  </view>
</view>
