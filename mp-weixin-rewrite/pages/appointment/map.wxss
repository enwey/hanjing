.appointment-map-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  width: 100%;
  box-sizing: border-box;
  background: #f9fafb;
}

.map-wrapper {
  position: relative;
  flex: 1;
  width: 100%;
  overflow: hidden;
}

.store-map {
  width: 100%;
  height: 100%;
}

.map-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  padding: 0 48rpx;
  text-align: center;
}

.map-empty__text {
  font-size: 28rpx;
  line-height: 1.7;
  color: #6b7280;
}

.store-card {
  position: absolute;
  left: 40rpx;
  right: 40rpx;
  bottom: 60rpx;
  z-index: 10;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  padding: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 20rpx 60rpx rgba(31, 41, 55, 0.12);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.store-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.store-name {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.4;
  color: #111827;
}

.store-address {
  font-size: 26rpx;
  line-height: 1.5;
  color: #6b7280;
}

.nav-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #3b6bf5 0%, #2a52d4 100%);
  box-shadow: 0 8rpx 28rpx rgba(59, 107, 245, 0.3);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
}

.nav-btn::after {
  border: 0;
}

.btn-icon {
  width: 32rpx;
  height: 32rpx;
  filter: brightness(0) invert(1);
}
