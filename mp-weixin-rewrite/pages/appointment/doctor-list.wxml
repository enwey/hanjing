<view class="page">
  <hj-navbar title="{{storeName || '推荐医生'}}" showBack="{{true}}" />

  <view class="page-content">
    <view class="section-header">
      <text class="section-title">选择医生</text>
      <text class="section-hint">共 {{doctors.length}} 位医生</text>
    </view>

    <view wx:if="{{doctors.length > 0}}">
      <view
        wx:for="{{doctors}}"
        wx:key="id"
        class="doctor-wrapper"
        data-doctor-id="{{item.id}}"
        bindtap="handleDoctorTap"
      >
        <hj-doctor-card doctor="{{item}}" />
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-text">该门店暂无医生排班</text>
    </view>
  </view>
</view>
