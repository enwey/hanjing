<view class="page">
  <hj-navbar title="选择门店" showBack="{{true}}" />

  <view class="page-content">
    <view class="section-header">
      <text class="section-title">请选择就诊门店</text>
      <text class="section-hint">共 {{stores.length}} 家门店</text>
    </view>

    <hj-store-card
      wx:for="{{stores}}"
      wx:key="id"
      store="{{item}}"
      distance="{{item.distanceLabel}}"
      bind:click="handleStoreTap"
    />
  </view>
</view>
