.page {
  min-height: 100vh;
  background: #f9fafb;
  box-sizing: border-box;
}

.page-content {
  padding-bottom: 180rpx;
}

.doctor-detail-hero {
  position: relative;
  padding: 120rpx 40rpx 56rpx;
  text-align: center;
  background: linear-gradient(160deg, #1a3580 0%, #3b6bf5 40%, #8eafff 100%);
}

.doc-avatar {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9999rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.15);
}

.doc-avatar-text {
  font-size: 72rpx;
  font-weight: bold;
  color: #ffffff;
}

.doc-name {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
}

.doc-title-text {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.doc-tags {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-top: 24rpx;
  flex-wrap: wrap;
}

.doc-hero-tag {
  padding: 6rpx 24rpx;
  border-radius: 9999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  background: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
}

.doc-stats-row {
  position: relative;
  z-index: 2;
  display: flex;
  margin: -32rpx 40rpx 0;
  padding: 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.doc-stat {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #f3f4f6;
}

.doc-stat:last-child {
  border-right: none;
}

.doc-stat .val {
  font-size: 40rpx;
  font-weight: 700;
  color: #3b6bf5;
}

.doc-stat .unit {
  margin-left: 4rpx;
  font-size: 24rpx;
  font-weight: 400;
  color: #9ca3af;
}

.doc-stat .lab {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #9ca3af;
}

.doc-section {
  padding: 40rpx;
}

.doc-section--schedule {
  padding-bottom: 180rpx;
}

.doc-section-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.doc-section-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}

.doc-intro {
  font-size: 28rpx;
  line-height: 1.8;
  color: #4b5563;
}

.doc-specialties {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.doc-spec-tag {
  padding: 12rpx 28rpx;
  border-radius: 9999rpx;
  background: #eef4ff;
  color: #3b6bf5;
  font-size: 24rpx;
  font-weight: 500;
}

.doc-schedule {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.schedule-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #f9fafb;
  border-radius: 24rpx;
}

.schedule-row .date {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.schedule-row .period {
  font-size: 24rpx;
  color: #6b7280;
}

.schedule-row .status {
  padding: 8rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.status-available {
  background: #ecfdf5;
  color: #059669;
}

.status-full {
  background: #f3f4f6;
  color: #9ca3af;
}

.schedule-empty {
  padding: 40rpx;
  border: 1rpx dashed #e5e7eb;
  border-radius: 24rpx;
  background: #f9fafb;
  color: #9ca3af;
  font-size: 28rpx;
  text-align: center;
}

.bottom-fixed-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  height: 140rpx;
  padding: 0 40rpx env(safe-area-inset-bottom, 0);
  background: #ffffff;
  border-top: 1rpx solid rgba(0, 0, 0, 0.08);
  box-sizing: content-box;
}

.bar-primary-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border: none;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #3b6bf5 0%, #5a85f5 50%, #8eafff 100%);
  box-shadow: 0 8rpx 28rpx rgba(59, 107, 245, 0.25);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.bar-primary-btn::after {
  border: none;
}

.bar-primary-btn--disabled {
  background: #d1d5db !important;
  box-shadow: none !important;
  color: #9ca3af !important;
}
