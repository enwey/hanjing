.page {
  min-height: 100vh;
  background: #f9fafb;
}

.page-content {
  padding: 0 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

.section-hint {
  font-size: 26rpx;
  color: #9ca3af;
}

.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}
