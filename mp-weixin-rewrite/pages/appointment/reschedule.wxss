.page {
  min-height: 100vh;
  background: #f9fafb;
}

.page-content {
  padding: 0 32rpx 48rpx;
}

.state-card {
  padding: 80rpx 0;
  text-align: center;
}

.state-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.schedule-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 28rpx 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
}

.schedule-period {
  margin-right: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.schedule-time {
  font-size: 28rpx;
  color: #6b7280;
}

.slot-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.slot {
  width: calc((100% - 32rpx) / 3);
  padding: 24rpx 0;
  border: 1rpx solid #e5e7eb;
  border-radius: 20rpx;
  background: #ffffff;
  text-align: center;
  font-size: 28rpx;
  color: #1f2937;
}

.slot--available {
  border-color: #3b6bf5;
  color: #3b6bf5;
}

.slot--selected {
  border-color: #3b6bf5;
  background: #3b6bf5;
  color: #ffffff;
}

.slot--booked {
  background: #f9fafb;
  color: #d1d5db;
  pointer-events: none;
}

.empty-card {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}

.submit-area {
  padding-top: 24rpx;
}
