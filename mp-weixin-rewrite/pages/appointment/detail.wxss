.page {
  min-height: 100vh;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom, 34px));
  box-sizing: border-box;
  background: #f4f6fa;
}

.page-content {
  padding: 32rpx;
}

.state-card {
  padding: 80rpx 40rpx;
  text-align: center;
}

.state-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.state-description {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.status-hero {
  position: relative;
  overflow: hidden;
  margin-bottom: 32rpx;
  padding: 48rpx 40rpx;
  border-radius: 40rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #3b6bf5 0%, #5a85f5 50%, #8eafff 100%);
  box-shadow: 0 16rpx 40rpx rgba(59, 107, 245, 0.15);
}

.status-hero.status--confirmed,
.status-hero.status--reminded {
  background: linear-gradient(135deg, #3b6bf5 0%, #5a85f5 50%, #8eafff 100%);
}

.status-hero.status--completed,
.status-hero.status--checked_in,
.status-hero.status--pending {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.status-hero.status--cancelled,
.status-hero.status--no_show,
.status-hero.status--arrived {
  background: linear-gradient(135deg, #9ca3af 0%, #6b7280 100%);
}

.status-hero-main {
  display: flex;
  align-items: center;
}

.status-icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  margin-right: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9999rpx;
  background: rgba(255, 255, 255, 0.2);
}

.status-icon {
  width: 48rpx;
  height: 48rpx;
  filter: brightness(0) invert(1);
}

.status-title-group {
  display: flex;
  flex-direction: column;
}

.status-title {
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  line-height: 1.5;
  opacity: 0.9;
}

.notice-card-warning {
  margin-bottom: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
}

.notice-content-wrapper {
  display: flex;
  align-items: flex-start;
}

.notice-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.notice-text-warning {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.6;
  color: #9a3412;
}

.order-no-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.no-text-group {
  display: flex;
  align-items: center;
}

.no-label {
  margin-right: 16rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.no-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

.copy-btn-action {
  width: 104rpx;
  height: 48rpx;
  line-height: 46rpx;
  margin: 0;
  padding: 0;
  border-radius: 12rpx;
  border: 1rpx solid rgba(59, 107, 245, 0.15);
  background: rgba(59, 107, 245, 0.08);
  color: #3b6bf5;
  font-size: 22rpx;
  font-weight: 500;
}

.copy-btn-action::after {
  border: none;
}

.copy-btn-hover {
  background: rgba(59, 107, 245, 0.15);
}

.card-premium {
  margin-bottom: 32rpx;
  padding: 40rpx;
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.doctor-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
}

.doc-avatar-large {
  width: 112rpx;
  height: 112rpx;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #3b6bf5 0%, #8eafff 100%);
  flex-shrink: 0;
}

.doc-avatar-text-large {
  color: #ffffff;
  font-size: 44rpx;
  font-weight: 700;
}

.doc-info-detail {
  flex: 1;
}

.doc-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.doc-name-large {
  margin-right: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

.doc-title-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #eef4ff;
  color: #3b6bf5;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1;
}

.doc-dept {
  display: block;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.doctor-expertise {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.doctor-expertise-tag {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #d3f5e3;
  color: #1a9d5c;
  font-size: 22rpx;
  line-height: 1.2;
}

.card-header-premium {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.header-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
}

.header-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.detail-rows {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.detail-row--clickable:active {
  opacity: 0.7;
}

.row-label {
  width: 144rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #9ca3af;
}

.row-value {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  line-height: 1.5;
  color: #374151;
  word-break: break-all;
}

.row-value--bold {
  color: #3b6bf5;
  font-weight: 700;
}

.row-value--small {
  font-size: 24rpx;
  color: #6b7280;
}

.row-value--price {
  color: #ef4444;
  font-weight: 600;
}

.row-value-group {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
}

.nav-icon {
  width: 28rpx;
  height: 28rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.symptom-card {
  border-left: 8rpx solid #3b6bf5;
}

.symptom-text-styled {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #374151;
}

.cancel-card-styled {
  border-left: 8rpx solid #ef4444;
}

.cancel-text-styled {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #ef4444;
}

.rating-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.rating-star {
  font-size: 48rpx;
  color: #d1d5db;
}

.rating-star--active {
  color: #f59e0b;
}

.eval-textarea {
  width: 100%;
  min-height: 180rpx;
  box-sizing: border-box;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f9fafb;
  font-size: 26rpx;
  color: #1f2937;
  line-height: 1.7;
}

.inline-submit-btn {
  margin-top: 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #3b6bf5 0%, #5a85f5 50%, #8eafff 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.inline-submit-btn::after {
  border: none;
}

.visit-notice-card {
  margin-bottom: 40rpx;
  padding: 32rpx;
  border: 1rpx solid #fde6b8;
  border-radius: 24rpx;
  background: #fffaf0;
}

.visit-notice-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.visit-notice-header-icon {
  width: 36rpx;
  margin-right: 12rpx;
  color: #f59e0b;
  font-size: 30rpx;
  line-height: 1;
}

.visit-notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #d97706;
}

.visit-notice-item {
  display: flex;
  align-items: flex-start;
  padding: 8rpx 0;
}

.visit-notice-index {
  width: 32rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  line-height: 1.5;
  color: #4b5563;
}

.visit-notice-text {
  flex: 1;
  font-size: 26rpx;
  line-height: 1.5;
  color: #4b5563;
}

.action-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  gap: 24rpx;
  padding: 32rpx 40rpx calc(32rpx + env(safe-area-inset-bottom, 34px));
  background: #ffffff;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.04);
}

.footer-btn {
  flex: 1;
  height: 92rpx;
  line-height: 90rpx;
  margin: 0;
  padding: 0;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.footer-btn::after {
  border: none;
}

.btn-primary-full {
  background: linear-gradient(135deg, #3b6bf5 0%, #5a85f5 50%, #8eafff 100%);
  box-shadow: 0 8rpx 28rpx rgba(59, 107, 245, 0.25);
  color: #ffffff;
}

.btn-ghost {
  border: 1rpx solid #d1d5db;
  background: #ffffff;
  color: #6b7280;
}

.btn-danger-ghost {
  border: 1rpx solid #fca5a5;
  background: #ffffff;
  color: #ef4444;
}

.footer-btn-hover {
  opacity: 0.9;
}
