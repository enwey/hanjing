.community-publish-page { min-height: 100vh; background: #f3f4f6; padding-bottom: calc(env(safe-area-inset-bottom, 34px) + 120rpx); }
.publish-form { padding: 20rpx 24rpx 0; }
.publish-field { margin-bottom: 24rpx; }
.publish-field__label { display: block; margin-bottom: 12rpx; font-size: 24rpx; color: #6b7280; font-weight: 600; }
.publish-category-list, .publish-tag-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.publish-chip { padding: 12rpx 20rpx; border-radius: 18rpx; border: 1rpx solid #e5e7eb; background: #ffffff; font-size: 22rpx; color: #6b7280; }
.publish-chip--active { border-color: #3b6bf5; background: #eef4ff; color: #3b6bf5; font-weight: 700; }
.publish-field__input, .publish-field__textarea { width: 100%; padding: 22rpx 20rpx; border-radius: 22rpx; background: #ffffff; box-sizing: border-box; color: #1f2937; }
.publish-field__input { min-height: 88rpx; font-size: 28rpx; }
.publish-field__textarea { min-height: 320rpx; font-size: 24rpx; line-height: 1.7; }
.publish-field__count { display: block; margin-top: 10rpx; text-align: right; font-size: 20rpx; color: #9ca3af; }
.publish-submit-bar { position: fixed; left: 0; right: 0; bottom: 0; z-index: 20; padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom, 0)); background: rgba(255,255,255,0.98); backdrop-filter: blur(14px); box-shadow: 0 -8rpx 24rpx rgba(15,23,42,0.06); }
.publish-submit-button { display: flex; align-items: center; justify-content: center; min-height: 92rpx; border-radius: 24rpx; background: linear-gradient(135deg, #3b6bf5, #2563eb); color: #ffffff; font-size: 28rpx; font-weight: 700; }
.publish-submit-button--disabled { opacity: 0.45; }
