.community-detail-page { min-height: 100vh; background: #f3f4f6; padding-bottom: calc(env(safe-area-inset-bottom, 34px) + 140rpx); }
.state-card { text-align: center; }
.state-card--error { border: 1rpx solid #fee2e2; }
.state-title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.state-desc { display: block; margin-top: 12rpx; font-size: 24rpx; line-height: 1.7; color: #6b7280; }
.state-button { display: inline-flex; align-items: center; justify-content: center; min-width: 220rpx; min-height: 76rpx; margin-top: 18rpx; border-radius: 9999rpx; background: linear-gradient(135deg, #3b6bf5, #5a85f5); color: #ffffff; font-size: 26rpx; font-weight: 700; }
.community-detail-content { padding: 20rpx 24rpx 0; }
.post-card { padding: 26rpx 24rpx 24rpx; border-radius: 28rpx; background: #ffffff; box-shadow: 0 12rpx 28rpx rgba(15,23,42,0.05); }
.post-header { display: flex; align-items: flex-start; gap: 18rpx; margin-bottom: 18rpx; }
.post-avatar { width: 80rpx; height: 80rpx; border-radius: 9999rpx; overflow: hidden; background: #e5e7eb; flex-shrink: 0; }
.post-avatar__image { width: 100%; height: 100%; }
.post-author { flex: 1; min-width: 0; }
.post-author__row { display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap; }
.post-author__name { font-size: 28rpx; font-weight: 700; color: #1f2937; }
.post-author__role { padding: 4rpx 12rpx; border-radius: 10rpx; font-size: 20rpx; }
.role--doctor { background: #eef4ff; color: #3b6bf5; }
.role--expert { background: #f5f3ff; color: #8b5cf6; }
.role--patient { background: #f0fdf4; color: #1a9d5c; }
.post-author__time { display: block; margin-top: 6rpx; font-size: 22rpx; color: #9ca3af; }
.post-report { display: inline-flex; align-items: center; gap: 6rpx; padding: 10rpx 16rpx; border-radius: 9999rpx; border: 1rpx solid #e5e7eb; }
.post-report__icon { width: 24rpx; height: 24rpx; }
.post-report__text { font-size: 20rpx; color: #9ca3af; }
.post-title { display: block; font-size: 34rpx; line-height: 1.55; font-weight: 700; color: #1f2937; }
.post-content { display: block; margin-top: 16rpx; font-size: 26rpx; line-height: 1.8; color: #4b5563; white-space: pre-wrap; }
.post-cover { width: 100%; height: 376rpx; margin-top: 18rpx; border-radius: 22rpx; background: #f3f4f6; }
.post-tags { display: flex; gap: 10rpx; flex-wrap: wrap; margin-top: 18rpx; }
.post-category, .post-tag { padding: 4rpx 14rpx; border-radius: 9999rpx; font-size: 20rpx; }
.post-tag { color: #3b6bf5; background: #eef4ff; }
.tag-theme--blue { color: #2a52d4; background: #e8f0ff; }
.tag-theme--green { color: #138a52; background: #e8f8ef; }
.tag-theme--orange { color: #d97706; background: #fff3df; }
.tag-theme--amber { color: #b7791f; background: #fff8db; }
.tag-theme--pink { color: #c2417a; background: #ffe8f1; }
.tag-theme--violet { color: #6d4fd6; background: #f0ebff; }
.post-actions { display: flex; gap: 28rpx; padding-top: 18rpx; margin-top: 18rpx; border-top: 1rpx solid #f3f4f6; }
.post-action { display: flex; align-items: center; gap: 8rpx; }
.post-action--passive { opacity: 0.88; }
.post-action__icon { width: 30rpx; height: 30rpx; }
.post-action__icon--liked { transform: scale(1.04); }
.post-action__count { font-size: 22rpx; color: #9ca3af; }
.comment-section { margin-top: 18rpx; }
.comment-section__header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx; }
.comment-section__title { font-size: 28rpx; font-weight: 700; color: #1f2937; }
.comment-section__total { font-size: 22rpx; color: #9ca3af; }
.comment-list { display: flex; flex-direction: column; gap: 16rpx; }
.comment-item { padding: 22rpx; border-radius: 24rpx; background: #ffffff; box-shadow: 0 8rpx 20rpx rgba(15,23,42,0.04); }
.comment-item__header { display: flex; align-items: center; gap: 14rpx; margin-bottom: 12rpx; }
.comment-item__avatar { width: 64rpx; height: 64rpx; border-radius: 9999rpx; overflow: hidden; background: #e5e7eb; }
.comment-item__avatar-image { width: 100%; height: 100%; }
.comment-item__info { flex: 1; }
.comment-item__author { display: block; font-size: 24rpx; font-weight: 700; color: #374151; }
.comment-item__time { display: block; margin-top: 4rpx; font-size: 20rpx; color: #9ca3af; }
.comment-item__reply-prefix { display: block; margin-bottom: 6rpx; font-size: 22rpx; color: #3b6bf5; }
.comment-item__content { display: block; font-size: 24rpx; line-height: 1.7; color: #4b5563; white-space: pre-wrap; }
.comment-item__actions { display: flex; align-items: center; gap: 18rpx; margin-top: 12rpx; }
.comment-item__action { display: inline-flex; align-items: center; gap: 6rpx; }
.comment-item__action-icon { width: 28rpx; height: 28rpx; }
.comment-item__action-icon--liked { transform: scale(1.04); }
.comment-item__action-count { font-size: 20rpx; color: #9ca3af; }
.comment-item__reply-link { font-size: 22rpx; color: #3b6bf5; font-weight: 700; }
.comment-empty { padding: 36rpx 24rpx; border-radius: 24rpx; background: #ffffff; text-align: center; }
.comment-empty__title { display: block; font-size: 28rpx; font-weight: 700; color: #1f2937; }
.comment-empty__desc { display: block; margin-top: 10rpx; font-size: 24rpx; line-height: 1.65; color: #9ca3af; }
.community-detail-content__safe-space { height: 100rpx; }
.comment-bar { position: fixed; left: 0; right: 0; bottom: 0; z-index: 20; padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom, 0)); background: rgba(255,255,255,0.98); backdrop-filter: blur(14px); border-top: 1rpx solid #e5e7eb; }
.reply-target { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; margin-bottom: 10rpx; }
.reply-target__text { font-size: 22rpx; color: #3b6bf5; }
.reply-target__clear { font-size: 22rpx; color: #9ca3af; }
.comment-bar__row { display: flex; align-items: center; gap: 14rpx; }
.comment-bar__input { flex: 1; min-height: 76rpx; padding: 0 22rpx; border-radius: 9999rpx; background: #f3f4f6; font-size: 24rpx; }
.comment-bar__send { display: flex; align-items: center; justify-content: center; min-width: 120rpx; min-height: 76rpx; border-radius: 9999rpx; background: linear-gradient(135deg, #3b6bf5, #5a85f5); color: #ffffff; font-size: 24rpx; font-weight: 700; }
.comment-bar__send--disabled { opacity: 0.45; }
