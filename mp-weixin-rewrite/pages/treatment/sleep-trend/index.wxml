<view class="container sleep-trend-page">
  <hj-navbar title="睡眠趋势" showBack="{{true}}" />

  <view class="page-section state-card" wx:if="{{loading}}">
    <text class="page-description">正在加载睡眠趋势...</text>
  </view>

  <view class="page-section state-card" wx:elif="{{loadError}}">
    <text class="state-title">加载失败</text>
    <text class="page-description">{{loadError}}</text>
  </view>

  <block wx:elif="{{hasRealData}}">
    <view class="page-section">
      <text wx:if="{{currentPatientLabel}}" class="current-patient-label">{{currentPatientLabel}}</text>
      <view class="range-tabs">
        <view class="range-tab {{selectedRange === 'week' ? 'range-tab--active' : ''}}" bindtap="switchToWeek">近7天</view>
        <view class="range-tab {{selectedRange === 'month' ? 'range-tab--active' : ''}}" bindtap="switchToMonth">本月</view>
      </view>
      <view class="summary-grid">
        <view class="summary-card"><text class="summary-card__value">{{wornDaysLabel}}</text><text class="summary-card__label">佩戴天数</text></view>
        <view class="summary-card"><text class="summary-card__value">{{avgDurationLabel}}</text><text class="summary-card__label">平均时长</text></view>
        <view class="summary-card"><text class="summary-card__value">{{complianceLabel}}</text><text class="summary-card__label">达标率</text></view>
        <view class="summary-card"><text class="summary-card__value">{{maxDurationLabel || '--'}}</text><text class="summary-card__label">最长时长</text></view>
      </view>
    </view>

    <view class="page-section">
      <view class="section-header">
        <text class="section-title">佩戴时长趋势</text>
        <text class="section-more" bindtap="openCalendar">完整日历</text>
      </view>
      <view class="chart">
        <view wx:for="{{chartItems}}" wx:key="dateLabel" class="chart-item">
          <text class="chart-item__value">{{item.durationLabel}}</text>
          <view class="chart-item__bar-wrap">
            <view class="chart-item__bar" style="height: {{item.barHeight}}; background: {{item.barColor}};"></view>
          </view>
          <text class="chart-item__date">{{item.dateLabel}}</text>
        </view>
      </view>
    </view>

    <view class="page-section">
      <text class="section-title">舒适度记录</text>
      <view class="comfort-list">
        <view wx:for="{{chartItems}}" wx:key="dateLabel" class="comfort-item">
          <view class="comfort-dots">
            <view wx:for="{{item.comfortDots}}" wx:key="index" class="comfort-dot {{item.active ? 'comfort-dot--active' : ''}}"></view>
          </view>
          <text class="comfort-item__date">{{item.dateLabel}}</text>
        </view>
      </view>
    </view>
  </block>

  <view class="page-section state-card" wx:else>
    <text class="state-title">暂无睡眠趋势数据</text>
    <text class="page-description">当前治疗人还没有可展示的真实佩戴记录，完成打卡后这里会展示趋势变化。</text>
  </view>
</view>
