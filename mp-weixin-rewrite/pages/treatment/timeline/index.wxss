.treatment-timeline-page { background: #f9fafb; padding-bottom: 40rpx; }
.state-card { text-align: center; }
.state-title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.hero-card { background: linear-gradient(135deg, #ffffff 0%, #eef4ff 100%); }
.section-title { display: block; margin-bottom: 20rpx; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.timeline-list { display: flex; flex-direction: column; gap: 12rpx; }
.timeline-item { display: flex; gap: 18rpx; }
.timeline-item__axis { width: 28rpx; display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
.timeline-item__dot { width: 18rpx; height: 18rpx; border-radius: 9999rpx; margin-top: 6rpx; }
.timeline-item__line { width: 4rpx; flex: 1; margin-top: 8rpx; border-radius: 9999rpx; min-height: 80rpx; }
.timeline-item__body { flex: 1; padding-bottom: 22rpx; }
.timeline-item__header { display: flex; align-items: center; gap: 14rpx; flex-wrap: wrap; }
.timeline-item__date { font-size: 24rpx; color: #6b7280; }
.timeline-item__type { padding: 6rpx 14rpx; border-radius: 9999rpx; background: rgba(59, 107, 245, 0.12); font-size: 22rpx; color: #3b6bf5; }
.timeline-item__title { display: block; margin-top: 10rpx; font-size: 28rpx; font-weight: 700; color: #1f2937; }
.timeline-item__desc, .timeline-item__doctor { display: block; margin-top: 10rpx; font-size: 24rpx; line-height: 1.7; color: #6b7280; }
.empty-action { display: inline-block; margin-top: 20rpx; font-size: 26rpx; font-weight: 600; color: #3b6bf5; }
