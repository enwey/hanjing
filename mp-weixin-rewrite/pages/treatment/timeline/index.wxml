<view class="container treatment-timeline-page">
  <hj-navbar title="治疗时间线" showBack="{{true}}" />

  <view class="page-section state-card" wx:if="{{loading}}">
    <text class="page-description">正在加载治疗时间线...</text>
  </view>

  <view class="page-section state-card" wx:elif="{{loadError}}">
    <text class="state-title">加载失败</text>
    <text class="page-description">{{loadError}}</text>
  </view>

  <block wx:elif="{{hasRealTreatmentRecord}}">
    <view class="page-section hero-card">
      <text class="page-title">{{deviceModel || '已建立治疗档案'}}</text>
      <text class="page-description" wx:if="{{adjustmentValue}}">当前参数：{{adjustmentValue}}</text>
      <text class="page-description" wx:if="{{nextAdjustDate}}">下次调整：{{nextAdjustDate}}</text>
    </view>

    <view class="page-section" wx:if="{{timelineItems.length}}">
      <text class="section-title">治疗动态</text>
      <view class="timeline-list">
        <view wx:for="{{timelineItems}}" wx:key="id" class="timeline-item">
          <view class="timeline-item__axis">
            <view class="timeline-item__dot" style="background: {{item.color}};"></view>
            <view wx:if="{{item.showLine}}" class="timeline-item__line" style="background: {{item.color}}33;"></view>
          </view>
          <view class="timeline-item__body">
            <view class="timeline-item__header">
              <text class="timeline-item__date">{{item.dateLabel}}</text>
              <text class="timeline-item__type">{{item.typeLabel}}</text>
            </view>
            <text class="timeline-item__title">{{item.title}}</text>
            <text class="timeline-item__desc">{{item.description}}</text>
            <text class="timeline-item__doctor" wx:if="{{item.doctorName}}">{{item.doctorName}}</text>
          </view>
        </view>
      </view>
    </view>
    <view class="page-section state-card" wx:else>
      <text class="state-title">暂无治疗进度记录</text>
    </view>
  </block>

  <view class="page-section state-card" wx:else>
    <text class="state-title">还没有治疗记录</text>
    <text class="page-description">当前治疗人还没有真实诊疗记录，完成预约问诊后这里会展示完整治疗动态。</text>
    <view class="empty-action" bindtap="goAppointment">前往预约</view>
  </view>
</view>
