.adjust-detail-page { background: #f9fafb; padding-bottom: 40rpx; }
.state-card { text-align: center; }
.state-title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.summary-card { background: linear-gradient(135deg, #eef4ff 0%, #ffffff 100%); }
.summary-card__title { display: block; font-size: 30rpx; font-weight: 700; color: #1f2937; }
.summary-card__meta { display: block; margin-top: 12rpx; font-size: 24rpx; line-height: 1.6; color: #4b5563; }
.history-list { display: flex; flex-direction: column; gap: 18rpx; }
.history-card { padding: 24rpx; border-radius: 24rpx; background: #ffffff; border: 1rpx solid #e5e7eb; }
.history-card__header { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.history-card__date, .history-card__value { font-size: 26rpx; font-weight: 700; color: #1f2937; }
.history-card__content, .history-card__meta { display: block; margin-top: 12rpx; font-size: 24rpx; line-height: 1.65; color: #4b5563; }
.empty-action { display: inline-block; margin-top: 20rpx; font-size: 26rpx; font-weight: 600; color: #3b6bf5; }
