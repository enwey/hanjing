.privacy-page { min-height: 100vh; background: #f9fafb; display: flex; flex-direction: column; }
.privacy-content { flex: 1; padding: 32rpx 24rpx; box-sizing: border-box; }
.article-title { font-size: 40rpx; font-weight: 700; color: #111827; text-align: center; margin-bottom: 12rpx; }
.article-meta { font-size: 22rpx; color: #9ca3af; text-align: center; margin-bottom: 32rpx; }
.section { margin-bottom: 20rpx; padding: 24rpx; border-radius: 24rpx; background: #ffffff; box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.05); }
.section-title { font-size: 28rpx; font-weight: 700; color: #1f2937; margin-bottom: 16rpx; }
.section-text { display: block; font-size: 24rpx; line-height: 1.8; color: #4b5563; }
