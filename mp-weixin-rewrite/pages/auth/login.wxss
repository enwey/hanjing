.login-page {
  min-height: calc(100vh - 88px);
  box-sizing: border-box;
  padding: 80rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.brand-section {
  margin-top: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.logo-container {
  width: 176rpx;
  height: 176rpx;
  margin-bottom: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b6bf5, #8eafff);
  box-shadow: 0 16rpx 48rpx rgba(59, 107, 245, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-emoji {
  font-size: 80rpx;
}

.brand-name {
  margin-bottom: 16rpx;
  font-size: 48rpx;
  font-weight: 700;
  color: #1a3580;
}

.brand-slogan {
  font-size: 26rpx;
  color: #6b7280;
}

.auth-section {
  width: 100%;
  margin-top: 100rpx;
  margin-bottom: auto;
}

.auth-tip-card {
  margin-bottom: 48rpx;
  padding: 32rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 32rpx;
  background: #f9fafb;
}

.tip-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.tip-content {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  color: #6b7280;
}

.auth-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  margin-bottom: 32rpx;
  border: none;
  border-radius: 24rpx;
  background: #07c160;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.25);
  text-align: center;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
}

.cancel-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  margin-bottom: 40rpx;
  border: none;
  border-radius: 24rpx;
  background: #f3f4f6;
  text-align: center;
  color: #4b5563;
  font-size: 32rpx;
  font-weight: 600;
}

.cancel-btn::after,
.auth-btn::after {
  border: none;
}

.protocol-section {
  margin-top: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  font-size: 22rpx;
  color: #9ca3af;
}

.protocol-label {
  display: flex;
  align-items: center;
}

.protocol-checkbox {
  transform: scale(0.65);
  margin-right: -4rpx;
}

.protocol-text {
  color: #9ca3af;
}

.protocol-link {
  color: #3b6bf5;
  display: inline;
}
